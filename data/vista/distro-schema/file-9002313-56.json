    {
      "fieldNumber": .03,
      "fieldName": "DEFAULT DEA #",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "Many insurances require the prescriber's DEA number as part of the  claim.  If your pharmacy has a DEA # that may be used in case a  prescriber doesn't have this DEA # on file with you, enter that default DEA # here. ",
      "fieldNumber_": .03
    },
    {
      "fieldNumber": .04,
      "fieldName": "LAST REGISTERED STATUS",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:ACTIVE;0:INACTIVE;",
      "helpText": "This field is set by the software in the background when registration messages are sent to Austin.  If the STATUS is Inactive and the last registered status is also Inactive then this pharmacy will not be registered again as Inactive. ",
      "fieldNumber_": .04
    },
    {
      "fieldNumber": .09,
      "fieldName": "AUTO-REVERSE PARAMETER",
      "dataType": "NUMERIC",
      "rawType": "RNJ2,0",
      "length": 2,
      "required": true,
      "helpText": "ECME shall use the following AUTO-REVERSE site parameter when determining whether non-released prescription claims (that have returned a PAYABLE response) are to be automatically REVERSED.   The AUTO-REVERSE site parameter is set for the number of days that ECME will wait before the claim is automatically REVERSED. The user is allowed to enter a number from 3 to 10. 5 is the suggested setting.   ECME will wait the entered number of days before REVERSING the non-released Rx with a PAYABLE respons",
      "fieldNumber_": .09
    },
    {
      "fieldNumber": .1,
      "fieldName": "STATUS",
      "dataType": "SET",
      "rawType": "RS",
      "required": true,
      "setOfCodes": "1:ACTIVE;0:INACTIVE;",
      "helpText": "Indicates whether a BPS Pharmacy is active or inactive. If active, claims  will be processed through ECME. ",
      "fieldNumber_": .1
    },
    {
      "fieldNumber": 1,
      "fieldName": "CMOP SWITCH",
      "dataType": "SET",
      "rawType": "RS",
      "required": true,
      "setOfCodes": "0:CMOP OFF;1:CMOP ON;",
      "helpText": "Indicates whether ECME shall process CMOP claims.  If ON, CMOP claims  will be processed.  If OFF, CMOP claims will not be processed. ",
      "fieldNumber_": 1
    },
    {
