      "dataType": "POINTER",
      "rawType": "RP123.5'",
      "required": true,
      "pointerTo": 123.5,
      "helpText": "The name of the Consult or Procedure request service or specialty to be added to the DICOM Modality Worklist and the HL7 Subscriber List. Example:  Hematology. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": 2,
      "fieldName": "PROCEDURE",
      "dataType": "POINTER",
      "rawType": "P123.3'",
      "required": false,
      "pointerTo": 123.3,
      "helpText": "A specific clinical specialty procedure associated with a given service. Example: Bone Marrow Biopsy. ",
      "fieldNumber_": 2
    },
    {
      "fieldNumber": 3,
      "fieldName": "SPECIALTY INDEX",
      "dataType": "POINTER",
      "rawType": "RP2005.84'",
