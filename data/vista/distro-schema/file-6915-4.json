      "fieldName": "ASSET VALUE 1",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "Identically equal to SUMMARY ASSET VALUE. Should be entered only for changes to an FA (BETTERMENT NUMBER=00). ",
      "fieldNumber_": 54
    },
    {
      "fieldNumber": 100,
      "fieldName": "CATEGORY STOCK NUMBER",
      "dataType": "POINTER",
