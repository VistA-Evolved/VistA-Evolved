  "fields": [
    {
      "fieldNumber": .01,
      "fieldName": "EQUIPMENT RECORD",
      "dataType": "POINTER",
      "rawType": "RP6914'",
      "required": true,
      "pointerTo": 6914,
      "helpText": "This field holds the internal entry number from file 6914 for the piece of capitalized NX equipment that an FC document was sent for. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": 1,
      "fieldName": "DATE/TIME CREATED",
      "dataType": "DATE",
      "rawType": "RD",
      "required": true,
      "helpText": "This is the date and time that the FC document was prepared. ",
      "fieldNumber_": 1
    },
    {
      "fieldNumber": 1.5,
      "fieldName": "SENDER",
      "dataType": "POINTER",
      "rawType": "RP200'",
      "required": true,
      "pointerTo": 200,
      "helpText": "This is the person who created the FC document using the change option. ",
      "fieldNumber_": 1.5
    },
    {
      "fieldNumber": 2,
      "fieldName": "SEGMENT 1 ID",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the Segment 1 ID for the FC document, usually it will be CTL. ",
      "fieldNumber_": 2
    },
    {
      "fieldNumber": 3,
      "fieldName": "SOURCE SYSTEM",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the source system for the FC document, usually AMM. ",
      "fieldNumber_": 3
    },
    {
      "fieldNumber": 4,
      "fieldName": "DESTINATION SYSTEM",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the system where the FC document is going, usually FMS. ",
      "fieldNumber_": 4
    },
    {
      "fieldNumber": 5,
      "fieldName": "SUBMITTING STATION",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the station number of the site that is submitting this FC document. ",
      "fieldNumber_": 5
    },
    {
      "fieldNumber": 6,
      "fieldName": "TRANSACTION CLASS",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the class of document being sent to FMS.  It is usually DOC, to represent a document transaction. ",
      "fieldNumber_": 6
    },
    {
      "fieldNumber": 7,
      "fieldName": "TRANSACTION CODE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This tells FMS what kind of document is being sent.  FC for an FC document. ",
      "fieldNumber_": 7
    },
    {
      "fieldNumber": 8,
      "fieldName": "SEC1 CODE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the Security 1 code of the submitting Administration/Staff office. VHA=10, VBA=20, and NCS=40. ",
      "fieldNumber_": 8
    },
    {
      "fieldNumber": 9,
      "fieldName": "BATCH NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the batch number of the FC document being sent.  Currently set to six spaces. ",
      "fieldNumber_": 9
    },
    {
      "fieldNumber": 10,
      "fieldName": "TRANSACTION NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the transaction number for this FC document.  It consists of the station number_the last digit of the fiscal year_N_the 4 digit sequential number. ",
      "fieldNumber_": 10
    },
    {
      "fieldNumber": 11,
      "fieldName": "TRANSACTION DATE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the date the FC document was created in YYYYMMDD format. ",
      "fieldNumber_": 11
    },
    {
      "fieldNumber": 12,
      "fieldName": "TRANSACTION TIME",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the time the FC document was created in HHMMSS format. ",
      "fieldNumber_": 12
    },
    {
      "fieldNumber": 13,
      "fieldName": "SEQUENCE NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the transaction part sequence number.  Should always be 001. ",
      "fieldNumber_": 13
    },
    {
      "fieldNumber": 14,
      "fieldName": "SEQUENCE TOTAL",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the total number of transaction parts.  Should always be 001. ",
      "fieldNumber_": 14
    },
    {
      "fieldNumber": 15,
      "fieldName": "VERSION",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the AMES/MERS-FMS interface version.  Should always be 001. ",
      "fieldNumber_": 15
    },
    {
      "fieldNumber": 16,
      "fieldName": "SEGMENT 2 ID",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the segment identifier for segment 2.  Should always be DOC. ",
      "fieldNumber_": 16
    },
    {
      "fieldNumber": 20,
      "fieldName": "SEGMENT 3 ID",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the segment identifier for the the FC1 segment.  Should always be FC1. ",
      "fieldNumber_": 20
    },
    {
      "fieldNumber": 21,
      "fieldName": "TRANS CODE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the Trans code for the FC1 segment.  Should always be FC. ",
      "fieldNumber_": 21
    },
    {
      "fieldNumber": 22,
      "fieldName": "TRANS DIVISION",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the Security 1 code.  VHA=10, VBA=20, NCS=40. ",
      "fieldNumber_": 22
    },
    {
      "fieldNumber": 23,
      "fieldName": "TRANS NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the transaction number for this FC document.  It consists of the station number_the last digit of the fiscal year_N_the 4 digit sequential number. ",
      "fieldNumber_": 23
    },
    {
      "fieldNumber": 24,
      "fieldName": "BEG BUDGET YEAR",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the beginning budget fiscal year. ",
      "fieldNumber_": 24
    },
    {
      "fieldNumber": 25,
      "fieldName": "FIXED ASSET NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "The fixed asset number consists of the submitting station_the 2 digit satelite station number (or 2 spaces if no satellite)_the internal entry number of the asset from file 6914. ",
      "fieldNumber_": 25
    },
    {
      "fieldNumber": 26,
      "fieldName": "FIXED ASSET TYPE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the FA TYPE field from the NX SGL file for this particular Standard General Ledger account. ",
      "fieldNumber_": 26
    },
    {
      "fieldNumber": 27,
      "fieldName": "BETTERMENT NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the betterment number if you are changing a betterment, otherwise it would be 00 since you would be changing the asset information. ",
      "fieldNumber_": 27
    },
    {
      "fieldNumber": 28,
      "fieldName": "FA GROUP",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "The group is derived from the Category Stock Number.  It is generally the first 2 digits of the CSN concatenated with 00, except for CSNs in the 7nnn range, which send as 7000, except for 7020, 7021, 7025, 7035, 7040, & 7050, which transmit as themselves. ",
      "fieldNumber_": 28
    },
    {
      "fieldNumber": 29,
      "fieldName": "LOCATION",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "The location is derived from the first 2 digits of the CMR.  Cll are valid except 67, 73, 74, 79-85, and 87-98. ",
      "fieldNumber_": 29
    },
    {
      "fieldNumber": 30,
      "fieldName": "DESCRIPTION",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is really the Category Stock Number. ",
      "fieldNumber_": 30
    },
    {
      "fieldNumber": 31,
      "fieldName": "ACQUISITION YEAR",
      "dataType": "FREE-TEXT",
      "rawType": "FX",
      "required": false,
      "helpText": "This is the year the item was acquired. ",
      "fieldNumber_": 31
    },
    {
      "fieldNumber": 32,
      "fieldName": "ACQUISITION MONTH",
      "dataType": "FREE-TEXT",
      "rawType": "FX",
      "required": false,
      "helpText": "This is the month the item was acquired. ",
      "fieldNumber_": 32
    },
    {
      "fieldNumber": 33,
      "fieldName": "ACQUISITION DAY",
      "dataType": "FREE-TEXT",
      "rawType": "FX",
      "required": false,
      "helpText": "This is the day the asset was acquired. ",
      "fieldNumber_": 33
    },
    {
      "fieldNumber": 34,
      "fieldName": "ACQUISITION METHOD",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "C:CONSTRUCTED;G:GIFT/BEQUEST/DONATION;L:LEASED;M:CAPITAL LEASE;O:OTHER;P:PURCHASED;R:TRANSFERRED;T:TRADED;X:EXCESS;",
      "helpText": "This is how the item was acquired; constructed, purchased, etc. ",
      "fieldNumber_": 34
    },
    {
      "fieldNumber": 35,
      "fieldName": "SEGMENT 4 ID",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the segment ID for the FC2 segment.  Should always be FC2. ",
      "fieldNumber_": 35
    },
    {
      "fieldNumber": 36,
      "fieldName": "UNITS",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the units that the item is measured in; each, gross, etc. ",
      "fieldNumber_": 36
    },
    {
      "fieldNumber": 37,
      "fieldName": "USEFUL LIFE",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the useful life expectancy in years for this item. ",
      "fieldNumber_": 37
    },
    {
      "fieldNumber": 38,
      "fieldName": "SALVAGE VALUE",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the expected salvage value upon disposing of the item.  Should be 0 for depreciable items. ",
      "fieldNumber_": 38
    },
    {
      "fieldNumber": 39,
      "fieldName": "DEPRECIATION METHOD",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is how the item will be depreciated.  Always SL (straight line) for NX equipment. ",
      "fieldNumber_": 39
    },
    {
      "fieldNumber": 40,
      "fieldName": "SUMMARY ASSET VALUE",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the new asset value that should be used in place of the original asset value on the code sheet being changed. When changing an FA Document (Betterment 00), enter the acquisition value of the asset. When changing a Betterment (Betterment 01, etc.), enter the value of the Betterment. ",
      "fieldNumber_": 40
    },
    {
      "fieldNumber": 41,
      "fieldName": "SELLING PRICE",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "Money recouped at sale of asset. ",
      "fieldNumber_": 41
    },
    {
      "fieldNumber": 42,
      "fieldName": "INCREASE-DECREASE",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "I:INCREASE;D:DECREASE;",
      "helpText": "For future use. ",
      "fieldNumber_": 42
    },
    {
      "fieldNumber": 43,
      "fieldName": "DISPOSITION METHOD CODE",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "Method by which asset was finally disposed of. ",
      "fieldNumber_": 43
    },
    {
      "fieldNumber": 44,
      "fieldName": "DISPOSITION YEAR",
      "dataType": "FREE-TEXT",
      "rawType": "FX",
      "required": false,
      "helpText": "Year in which asset was disposed of (YYYY). ",
      "fieldNumber_": 44
    },
    {
      "fieldNumber": 45,
      "fieldName": "DISPOSITION MONTH",
      "dataType": "FREE-TEXT",
      "rawType": "FX",
      "required": false,
      "helpText": "Numeric representation of disposition month (ex: 09 for September). Leading zeroes must be included for January thru September. ",
      "fieldNumber_": 45
    },
    {
      "fieldNumber": 46,
      "fieldName": "DISPOSITION DAY",
      "dataType": "FREE-TEXT",
      "rawType": "FX",
      "required": false,
      "helpText": "Disposition day. Leading zeroes must be included for the first thru the ninth. ",
      "fieldNumber_": 46
    },
    {
      "fieldNumber": 47,
      "fieldName": "FUNDING SOURCE",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "For future use. ",
      "fieldNumber_": 47
    },
    {
      "fieldNumber": 48,
      "fieldName": "REPLACEMENT YEAR",
      "dataType": "FREE-TEXT",
      "rawType": "FX",
      "required": false,
      "helpText": "Calendar year in which asset is scheduled for replacement. ",
      "fieldNumber_": 48
    },
    {
      "fieldNumber": 49,
      "fieldName": "REPLACEMENT MONTH",
      "dataType": "FREE-TEXT",
      "rawType": "FX",
      "required": false,
      "helpText": "Numeric representation of month in which asset is scheduled to be replaced (ex: 09 for September). Leading zeroes are required for January thru September. ",
      "fieldNumber_": 49
    },
    {
      "fieldNumber": 50,
      "fieldName": "REPLACEMENT DAY",
      "dataType": "FREE-TEXT",
      "rawType": "FX",
      "required": false,
      "helpText": "Day on which asset is scheduled to be replaced. Leading zeroes required for the first thru the ninth. ",
      "fieldNumber_": 50
    },
    {
