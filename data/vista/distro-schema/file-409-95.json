    {
      "fieldNumber": .1,
      "fieldName": "DON'T USE PCMM PROVIDERS",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "0:NO;1:YES;",
      "helpText": "AICS defaults to printing providers specified in PCMM if they are defined otherwise the providers from the clinic setup is used. Answering this field \"YES\" for a clinic will cause AICS to print the providers from clinic setup irregardless PCMM.  This is intended for use by sites bringing up PCMM but who have not completed the entry of providers. ",
      "fieldNumber_": .1
    },
    {
      "fieldNumber": 1,
      "fieldName": "REPORT",
      "dataType": "POINTER",
      "rawType": "409.9501IP",
      "required": false,
      "helpText": "  This is a list of reports or forms that should be printed under certain circumstances. The only types of forms or reports that can be printed are ones that are defined in the Package Interface file. ",
