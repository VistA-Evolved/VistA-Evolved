    {
      "fieldNumber": .05,
      "fieldName": "FORM W/O PATIENT DATA",
      "dataType": "POINTER",
      "rawType": "*P357'",
      "required": false,
      "pointerTo": 357,
      "helpText": "  This is the encounter form that should be printed for unscheduled visits. It may have a space in the top left hand corner for imprinting the embossed patient card or space to write in the name, ssn, etc. ",
      "fieldNumber_": .05
    },
    {
      "fieldNumber": .06,
      "fieldName": "SUPPLMNTL FORM #1 ALL PATIENTS",
      "dataType": "POINTER",
      "rawType": "*P357'",
      "required": false,
      "pointerTo": 357,
      "helpText": "  This is a supplemental form to be used by all patients of the clinic. A form in this category should not also be in one of the other categories for supplemental forms, else it will be printed twice. ",
      "fieldNumber_": .06
    },
    {
      "fieldNumber": .07,
      "fieldName": "RESERVED FOR FUTURE USE",
      "dataType": "POINTER",
      "rawType": "*P357'",
      "required": false,
      "pointerTo": 357,
      "helpText": "This category was created for clinics to assign new forms that are not yet complete without fear that they would be accidently printed. ",
