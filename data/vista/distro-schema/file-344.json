      "rawType": "RFX",
      "required": true,
      "helpText": "This field should reflect the field service receipt number. This field is assigned during entry of payments and will separate different types of payment (cash, check, or credit card) for a particular user for a given time-frame. ",
      "fieldNumber_": .01
    },
