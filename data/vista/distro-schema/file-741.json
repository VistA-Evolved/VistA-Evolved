      "dataType": "POINTER",
      "rawType": "*P741.6'O",
      "required": false,
      "pointerTo": 741.6,
      "helpText": "This is the validated/confirmed quality of care. ",
      "fieldNumber_": 20
    },
    {
      "fieldNumber": 21,
      "fieldName": "*VALIDATED/CONFIRMED",
      "dataType": "SET",
      "rawType": "S",
