  "fields": [
    {
      "fieldNumber": .01,
      "fieldName": "QA PATIENT",
      "dataType": "POINTER",
      "rawType": "RP2'",
      "required": true,
      "pointerTo": 2,
      "helpText": "Select a patient who has met one of the screens.  A patient may be selected by: Name, SSN, Last four digits of SSN, or Last initial and last four digits of SSN. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": .02,
      "fieldName": "ASSOCIATED ADMISSION",
      "dataType": "POINTER",
      "rawType": "*P405'",
      "required": false,
      "pointerTo": 405,
      "helpText": "This field contains the MAS admission movement associated with this occurrence. ",
      "fieldNumber_": .02
    },
    {
      "fieldNumber": 1,
      "fieldName": "DATE",
      "dataType": "DATE",
      "rawType": "RDX",
      "required": true,
      "helpText": "This is the date the occurrence took place.  For auto enrolled occurrences it is the date that this occurrence was picked up by auto enroll. ",
      "fieldNumber_": 1
    },
    {
      "fieldNumber": 2,
      "fieldName": "OCCURRENCE IDENTIFIER",
      "dataType": "FREE-TEXT",
      "rawType": "RFI",
      "required": true,
      "helpText": "This identifier is computed from the patient's name, SSN, occurrence date and internal entry number in the occurrence screen file. ",
      "fieldNumber_": 2
    },
    {
      "fieldNumber": 3,
      "fieldName": "SCREEN",
      "dataType": "POINTER",
      "rawType": "R*P741.1'",
      "required": true,
      "pointerTo": 741.1,
      "helpText": "This is the screen that best describes this patient's occurrence. ",
      "fieldNumber_": 3
    },
    {
      "fieldNumber": 4,
      "fieldName": "WARD/CLINIC",
      "dataType": "POINTER",
