      "helpText": "This is the treating specialty associated with this occurrence. ",
      "fieldNumber_": 6
    },
    {
      "fieldNumber": 7,
      "fieldName": "MEDICAL TEAM",
      "dataType": "POINTER",
      "rawType": "P741.93'",
      "required": false,
      "pointerTo": 741.93,
      "helpText": "This is the medical team associated with this occurrence. ",
      "fieldNumber_": 7
    },
    {
      "fieldNumber": 8,
      "fieldName": "ATTENDING PHYSICIAN",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "This is the patient's attending physician. ",
      "fieldNumber_": 8
    },
    {
      "fieldNumber": 9,
      "fieldName": "RESIDENT/PROVIDER",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "This is the patient's resident/provider. ",
      "fieldNumber_": 9
    },
    {
      "fieldNumber": 10,
      "fieldName": "REVIEWER",
      "dataType": "POINTER",
      "rawType": "741.01IPA",
      "required": false,
      "helpText": "This is where the reviewer data for Clinical, Peer, and Management reviews is entered or changed. ",
      "fieldNumber_": 10
    },
    {
      "fieldNumber": 11,
      "fieldName": "STATUS",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "0:OPEN;1:CLOSED;2:DELETED;",
      "helpText": "This is the status of this occurrence record.  Occurrences are automatically marked as open when they are first entered into the system.  When a final disposition date is entered they are marked as closed.  An occurrence may be marked as deleted at any time by using the delete occurrence screen record option in the manager menu. ",
      "fieldNumber_": 11
    },
    {
      "fieldNumber": 12,
      "fieldName": "PEER DUE DATE",
      "dataType": "DATE",
      "rawType": "DI",
      "required": false,
      "helpText": "This is the date all peer reviews should be completed by.  It is computed by adding the peer review days entry in the parameters file to the date the clinical review was completed. ",
      "fieldNumber_": 12
    },
    {
      "fieldNumber": 13,
      "fieldName": "MANAGEMENT DUE DATE",
      "dataType": "DATE",
      "rawType": "DI",
      "required": false,
      "helpText": "This is the date by which all management reviews should be completed. It is computed by adding the management review days entry from the parameters file to the date the clinical review was completed. ",
      "fieldNumber_": 13
    },
    {
      "fieldNumber": 14,
      "fieldName": "FINAL DISPOSITION DATE",
      "dataType": "DATE",
      "rawType": "DX",
      "required": false,
      "helpText": "This is the date of the final disposition.  Only the last final disposition is tracked.  Some options allow this date to be entered manually, while others automatically store the current date. ",
      "fieldNumber_": 14
    },
    {
      "fieldNumber": 15,
      "fieldName": "TOTAL ELAPSED DAYS",
      "dataType": "NUMERIC",
      "rawType": "NJ3,0",
      "length": 3,
      "required": false,
      "helpText": "This is the number of days between the occurrence date and the final disposition date. ",
      "fieldNumber_": 15
    },
    {
      "fieldNumber": 16,
      "fieldName": "FINAL DISPOSITION REACHED BY",
      "dataType": "POINTER",
      "rawType": "*P741.2'",
      "required": false,
      "pointerTo": 741.2,
      "helpText": "This field tracks which review level entered a final disposition.  Some options allow data to be entered manually while others automatically store the data. ",
      "fieldNumber_": 16
    },
    {
      "fieldNumber": 17,
      "fieldName": "COMMITTEE",
      "dataType": "POINTER",
      "rawType": "741.017PA",
      "required": false,
      "helpText": "This is where all data on committee reviews is stored. ",
      "fieldNumber_": 17
    },
    {
      "fieldNumber": 18,
      "fieldName": "*DATE VALIDATED/CONFIRMED",
      "dataType": "DATE",
      "rawType": "DX",
