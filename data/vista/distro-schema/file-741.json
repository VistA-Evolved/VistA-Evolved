      "helpText": "This is the type of problem that led to this occurrence. ",
      "fieldNumber_": 21
    },
    {
      "fieldNumber": 22,
      "fieldName": "*VALIDATION COMMENT",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "Enter any comment regarding the validation of this occurrence. ",
      "fieldNumber_": 22
    },
    {
