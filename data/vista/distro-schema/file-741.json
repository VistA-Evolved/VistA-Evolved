      "pointerTo": 44,
      "helpText": "This is the ward/clinic of the occurrence as defined by the Occurrence Screen circular. ",
      "fieldNumber_": 4
    },
    {
      "fieldNumber": 5,
      "fieldName": "SERVICE",
      "dataType": "POINTER",
      "rawType": "P49'",
      "required": false,
      "pointerTo": 49,
      "helpText": "This is the service associated with this occurrence. ",
      "fieldNumber_": 5
    },
    {
