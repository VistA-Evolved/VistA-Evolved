      "fieldName": "ID NUMBER",
      "dataType": "NUMERIC",
      "rawType": "RNJ12,0X",
      "length": 12,
      "required": true,
      "helpText": "This is the violation ID #.  It is the site # concatenated with year and the internal entry number. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": .02,
      "fieldName": "DATE/TIME OF OFFENSE",
      "dataType": "DATE",
      "rawType": "RDX",
      "required": true,
      "helpText": "The date/time of the commission of the offense charged.  Future dates  are not allowed.  Enter the date/time of the commission of the offense charged.  BOTH date and time must be entered. ",
      "fieldNumber_": .02
    },
    {
      "fieldNumber": .03,
      "fieldName": "COURTESY/VIOLATION",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "C:COURTESY;V:USDCVN;",
      "helpText": "Enter 'C' if this is a courtesy ticket or 'V' if this is a USDCVN. ",
      "fieldNumber_": .03
    },
    {
      "fieldNumber": .04,
      "fieldName": "OFFENSE CHARGED",
      "dataType": "POINTER",
      "rawType": "RP915'",
      "required": true,
      "pointerTo": 915,
      "helpText": "Enter the specific statute or regulation violated. ",
      "fieldNumber_": .04
    },
    {
      "fieldNumber": .05,
      "fieldName": "VIOLATION NUMBER",
      "dataType": "NUMERIC",
      "rawType": "RNJ7,0X",
      "length": 7,
      "required": true,
      "helpText": "Enter the number assigned to the U.S.D.C. Violation Notice.  Enter only the numerics of the number, the \"V\" is understood to exist since it has already been designated as a Violation Notice. ",
      "fieldNumber_": .05
    },
    {
      "fieldNumber": .06,
      "fieldName": "ISSUING OFFICER",
      "dataType": "POINTER",
