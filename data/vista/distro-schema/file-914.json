      "fieldName": "OFFENSE DESCRIPTION",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "The description of the violation charged.  This space may be used to provide shorthand titles for common violations such as speeding or parking. This type of entry may be useful in developing violation trend studies. ",
      "fieldNumber_": .08
    },
