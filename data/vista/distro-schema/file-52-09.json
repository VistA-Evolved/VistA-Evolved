      "fieldNumber_": .06
    },
    {
      "fieldNumber": .061,
      "fieldName": "REMOTE FILLING PHARMACIST",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the pharmacist taking action on the selected RX. ",
      "fieldNumber_": .061
    },
    {
      "fieldNumber": .07,
      "fieldName": "QUANTITY",
      "dataType": "NUMERIC",
      "rawType": "NJ4,0",
