      "fieldName": "LOG DATE/TIME",
      "dataType": "DATE",
      "rawType": "RD",
      "required": true,
      "helpText": "This is the date/time associated with this remote prescription  transaction. The date/time represents the date/time the message was  processed and filed locally. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": .02,
      "fieldName": "PATIENT",
      "dataType": "POINTER",
      "rawType": "RP2'",
      "required": true,
      "pointerTo": 2,
      "helpText": "This is the patient for which a refill or partial fill request was  generated. ",
      "fieldNumber_": .02
    },
    {
      "fieldNumber": .03,
      "fieldName": "RX NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "The RX# as stored at the remote facility. ",
      "fieldNumber_": .03
    },
    {
      "fieldNumber": .04,
      "fieldName": "SITE NUMBER",
