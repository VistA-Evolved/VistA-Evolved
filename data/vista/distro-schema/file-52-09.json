      "fieldNumber_": .04
    },
    {
      "fieldNumber": .05,
      "fieldName": "REQUEST TYPE",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "RF:REFILL;PR:PARTIAL FILL;OR:OUTSIDE REFILL;OP:OUTSIDE PARTIAL FILL;",
      "helpText": "This fields holds the type of request being made for this RX. ",
      "fieldNumber_": .05
    },
    {
