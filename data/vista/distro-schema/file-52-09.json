      "rawType": "NJ3,0",
      "length": 3,
      "required": false,
      "helpText": "This is the days supply for this refill or partial fill action. ",
      "fieldNumber_": .08
    },
    {
      "fieldNumber": .09,
      "fieldName": "REFILL/PARTIAL DATE",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date for the refill or partial fill request. This represents  the date/time as it is logged in the .01 field of either the REFILL or PARTIAL fill. subfile within the PRESCRIPTION file (#52) on the remote system. ",
      "fieldNumber_": .09
    },
    {
