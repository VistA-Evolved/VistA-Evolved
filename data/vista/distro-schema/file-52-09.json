      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the Dispense date/time as it is held in the DISPENSED DATE within  the REFILL subfile of the PRESCRIPTION (#52) file, or the DISPENSED DATE  within the PARTIAL subfile of the PRESCRIPTION file. ",
      "fieldNumber_": .1
    },
