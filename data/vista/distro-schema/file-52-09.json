      "rawType": "P50'",
      "required": false,
      "pointerTo": 50,
      "helpText": "This is the drug that was used for locally for the 'remote' refill or  partial fill. Since drug IENS and names may differ between sites, a user  must match the remote drug name to a local drug. ",
      "fieldNumber_": 1.1
    },
    {
