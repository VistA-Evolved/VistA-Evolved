{
  "fileNumber": 443.75,
  "fileName": "EDI SENDER",
  "globalRoot": "443.75",
  "globalReference": "^PRC(443.75,",
  "ddAccess": "N",
  "securityAudit": "audited",
  "fields": [
    {
      "fieldNumber": .01,
      "fieldName": "SEQUENTIAL ENTRY NUMBER",
      "dataType": "NUMERIC",
      "rawType": "RNJ10,0",
      "length": 10,
      "required": true,
      "helpText": "This field contains a sequential number.  This number is not linked to the file's IEN. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": 1,
      "fieldName": "PO/RFQ NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "Enter the reference number for the Purchase Order, Requesition, Request for Quotation or Text supplement to a RFQ. ",
      "fieldNumber_": 1
    },
    {
      "fieldNumber": 2,
      "fieldName": "TXT MESSAGE NUMBER",
      "dataType": "NUMERIC",
      "rawType": "NJ3,0",
      "length": 3,
      "required": false,
      "helpText": "This TXT number is a sequential number entered for each text record sent out about a RFQ document. ",
      "fieldNumber_": 2
    },
    {
      "fieldNumber": 3,
      "fieldName": "TYPE OF TRANSACTION",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "PHA:PHA;RFQ:RFQ;TXT:TXT;",
      "helpText": "Enter the type of transaction created. ",
      "fieldNumber_": 3
    },
    {
      "fieldNumber": 4,
      "fieldName": "MAIL MESSAGE NUMBER",
      "dataType": "NUMERIC",
      "rawType": "NJ12,0",
      "length": 12,
      "required": false,
      "helpText": "This field has the MailMan message number that the PHA, or RFQ or TXT transaction is using as an envelope to go to Austin. ",
      "fieldNumber_": 4
    },
    {
      "fieldNumber": 5,
      "fieldName": "VENDOR ID NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "The VENDOR ID NUMBER is the identifer for the vendor or vendors listed in the outgoing PHA, or RFQ or TXT transaction.  Each vendor will be listed under a different record within this file for all vendors entered within a RFQ. ",
      "fieldNumber_": 5
    },
    {
      "fieldNumber": 5.5,
      "fieldName": "SENDER",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "fieldNumber_": 5.5
    },
    {
      "fieldNumber": 6,
      "fieldName": "DATE/TIME CREATED",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This field will contain the date and time that the MailMan message was created.  This will be within 15 minuts of when the transaction was created. ",
      "fieldNumber_": 6
    },
    {
      "fieldNumber": 6.5,
      "fieldName": "RFQ",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "00:NEW RFQ;01:CANCELLED RFQ;",
      "helpText": "The code '00' means that an initial RFQ transaction is being sent.  '01' means that this RFQ transaction is cancelling the request. ",
      "fieldNumber_": 6.5
    },
    {
      "fieldNumber": 7,
      "fieldName": "PO POINTER",
      "dataType": "POINTER",
      "rawType": "P442'",
      "required": false,
      "pointerTo": 442,
      "helpText": "Enter here the internal entry number for the record in file 442 that the PO/RFQ NUMBER field identifies.  This pointer will only represent records that create PHA transactions. ",
      "fieldNumber_": 7
    },
    {
      "fieldNumber": 8,
      "fieldName": "RFQ/TXT POINTER",
      "dataType": "POINTER",
      "rawType": "P444'",
      "required": false,
      "pointerTo": 444,
      "helpText": "This field points to the record in file 444 that the PO/RFQ NUMBER field lists. ",
      "fieldNumber_": 8
    },
    {
      "fieldNumber": 9,
      "fieldName": "INCOMMING TYPE OF TRANSACTION",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "ACT:ACT;PRJ:PRJ;",
      "helpText": "'ACT' means the transaction is reporting on 'PHA', 'RFQ' or 'TXT' which were accepted in Austin following transmission from the site. 'PRJ' means the transaction is reporting on transactions rejected in Austin. ",
      "fieldNumber_": 9
    },
    {
      "fieldNumber": 10,
      "fieldName": "DATE/TIME PROCESSED",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "fieldNumber_": 10
    },
    {
      "fieldNumber": 11,
      "fieldName": "INCORRECT SEGMENT",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "The data for this field comes from the INCORRECT SEGMENT field in the RJ segment within the PRJ transaction.  This transaction reports problems within the PHA, RFQ or TXT transactions sent to Austin. ",
      "fieldNumber_": 11
    },
    {
      "fieldNumber": 12,
      "fieldName": "INCORRECT FIELD NAME",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "Enter the name of the field within a segment in the PHA, RFQ or TXT transaction that Austin considers to be in error. ",
      "fieldNumber_": 12
    },
    {
      "fieldNumber": 13,
      "fieldName": "FIELD CONTAINES",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the data that Austin received in the INCORRECT FIELD NAME entry. ",
      "fieldNumber_": 13
    },
    {
      "fieldNumber": 14,
      "fieldName": "ITEM LINE NUMBER",
      "dataType": "NUMERIC",
      "rawType": "NJ4,0",
      "length": 4,
      "required": false,
      "helpText": "This is the LINE ITEM NUMBER from the IT segment of the PHA or RFQ transaction with the error. ",
      "fieldNumber_": 14
    },
    {
      "fieldNumber": 15,
      "fieldName": "REJECT REASON CODE",
      "dataType": "POINTER",
      "rawType": "P443.76'",
      "required": false,
      "pointerTo": 443.76,
      "helpText": "Enter the REJECT REASON value from the RJ segment within the PRJ transaction.  This is the explination about the error within the PHA, RFQ or TXT transaction sent to Austin. ",
      "fieldNumber_": 15
    },
    {
      "fieldNumber": 16,
      "fieldName": "DESCRIPTION LINE NUMBER",
      "dataType": "NUMERIC",
      "rawType": "NJ4,0",
      "length": 4,
      "required": false,
      "helpText": "Enter the line number of the DE segment with the problem reported from Austin. ",
      "fieldNumber_": 16
    },
    {
      "fieldNumber": 17,
      "fieldName": "DE SEQUENCE NUMBER",
      "dataType": "NUMERIC",
      "rawType": "NJ3,0",
      "length": 3,
      "required": false,
      "helpText": "Enter the number from the DE SEQUENCE NUMBER in the RJ segment within the PRJ transaction from Austin. ",
      "fieldNumber_": 17
    },
    {
      "fieldNumber": 18,
      "fieldName": "CO SEQUENCE NUMBER",
      "dataType": "NUMERIC",
      "rawType": "NJ3,0",
      "length": 3,
      "required": false,
      "helpText": "Enter the CO SEQUENCE NO. field from the RJ segment within the PRJ transaction comming from Austin. ",
      "fieldNumber_": 18
    },
    {
      "fieldNumber": 19,
      "fieldName": "TRANSACTION ERROR",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "E:ERROR IN TRANSACTION;R:REPAIRED TRANSACTION;",
      "helpText": "This field is set if there is a problem with the incomming transaction. Once the problem with the record is corrected this field should be changed to REPAIRED TRANSACTION. ",
      "fieldNumber_": 19
    },
    {
      "fieldNumber": 20,
      "fieldName": "ERROR REASON",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "fieldNumber_": 20
    },
    {
      "fieldNumber": 21,
      "fieldName": "TOTAL NUMBER",
      "dataType": "NUMERIC",
      "rawType": "NJ3,0",
      "length": 3,
      "required": false,
      "fieldNumber_": 21
    },
    {
      "fieldNumber": 22,
      "fieldName": "SEQUENCE NUMBER",
      "dataType": "NUMERIC",
      "rawType": "NJ3,0",
      "length": 3,
      "required": false,
      "fieldNumber_": 22
    },
    {
      "fieldNumber": 23,
      "fieldName": "POA TRANSACTION",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "POA:POA;",
      "helpText": "Indicates entry is associated with a Purchase Order Acknowledgement (POA) transaction from the vendor. ",
      "fieldNumber_": 23
    },
    {
      "fieldNumber": 24,
      "fieldName": "DATE/TIME SENT",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "fieldNumber_": 24
    },
    {
      "fieldNumber": 25,
      "fieldName": "PROGRESS LEVEL",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:SENT FROM IFCAP;2:RECEIVED FROM IFCAP (ACCEPTED OR REJECTED);3:STATUS FROM VENDOR;",
      "fieldNumber_": 25
    },
    {
      "fieldNumber": 26,
      "fieldName": "POA ERROR",
      "dataType": "SUBFILE",
      "rawType": "443.7526A",
      "required": false,
      "isMultiple": true,
      "subFileNumber": 443.7526,
      "fieldNumber_": 26
    }
  ],
