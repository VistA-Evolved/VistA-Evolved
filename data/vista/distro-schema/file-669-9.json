      "dataType": "FREE-TEXT",
      "rawType": "RFX",
      "required": true,
      "helpText": "The site name can be either uppercase, or a combination of upper and lower. This is the name of your Medical Center, and should be entered the way you would like to have it print on your forms.  For example: Carl T. Hayden VAMC. ",
      "fieldNumber_": .01
    },
