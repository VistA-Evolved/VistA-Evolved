    },
    {
      "fieldNumber": 1.06,
      "fieldName": "PRODUCTION STATUS",
      "dataType": "SET",
      "rawType": "*S",
      "required": false,
      "setOfCodes": "0:DISABLED;1:DEVELOPMENT;2:FIELD TESTING;3:PRODUCTION;",
      "helpText": "To be used as a screen when attaching a format to an insurer. Don't allow non-production formats.  Those will have to be entered directly with Fileman. ",
      "fieldNumber_": 1.06
    },
    {
      "fieldNumber": 1.1,
      "fieldName": "TOTAL EXCLUSIVE PATIENT AMOUNT",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:Y;0:N;",
      "helpText": "This refers to the interpretation of the fields in the response packets, as copied to 9002313.03, Response(s) multiple, fields 509 Total Amount Paid and 505 Patient Paid Amount.  For most formats and insurers 509 Total Amount Paid means Total, Patient plus Insurer.  Other insurers don't do it that way - for them, 509 contains only the amount paid by insurance. $$NETPAID1 needs to know whether to do the subtraction.  If $$NETPAID1 encounters a case where (#509)<(#505), it will set the flag in the",
      "fieldNumber_": 1.1
    },
    {
