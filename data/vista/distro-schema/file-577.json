      "rawType": "RF",
      "required": true,
      "helpText": "The name of this VDEF Event. This MUST consist of the HL7 Message Type,  HL7 Event Type and a VDEF subtype.  Valid examples are: ORU-R01-VTLS, RDS-O13-PPAR, ADT-A01-DEMG. ",
      "fieldNumber_": .01
    },
