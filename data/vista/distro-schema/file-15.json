{
  "fileNumber": 15,
  "fileName": "DUPLICATE RECORD",
  "globalRoot": "15V",
  "globalReference": "^VA(15,",
  "ddAccess": "N",
  "securityAudit": "audited",
  "fields": [
    {
      "fieldNumber": .01,
      "fieldName": "RECORD1",
      "dataType": "VARIABLE-POINTER",
      "rawType": "RVXI",
      "required": true,
      "helpText": "This field contains one of the potential duplicate pair.  This is a variable pointer. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": .02,
      "fieldName": "RECORD2",
      "dataType": "VARIABLE-POINTER",
      "rawType": "RVXI",
      "required": true,
      "helpText": "The second of the potential duplicate pair.  This is a variable pointer. ",
      "fieldNumber_": .02
    },
    {
      "fieldNumber": .03,
      "fieldName": "STATUS",
      "dataType": "SET",
      "rawType": "R*S",
      "required": true,
      "setOfCodes": "P:POTENTIAL DUPLICATE, UNVERIFIED;N:VERIFIED, NOT A DUPLICATE;V:VERIFIED DUPLICATE;X:VERIFICATION IN PROCESS;R:REQUIRES RESOLUTION;",
      "helpText": "This field indicates the status of this duplicate record pair.  It may be 'potential duplicate, unverified', 'verified, not a duplicate', or 'verified duplicate'.  This field cannot be modified once MERGE STATUS is set to 2=MERGED. ",
      "fieldNumber_": .03
    },
    {
      "fieldNumber": .04,
      "fieldName": "MERGE DIRECTION",
      "dataType": "SET",
      "rawType": "R*SI",
      "required": true,
      "setOfCodes": "1:RECORD1 to RECORD2;2:RECORD2 to RECORD1;",
      "helpText": "This field indicates in which direction the merge is to occur, RECORD1 to RECORD2 or RECORD2 to RECORD1.  This field cannot be modified once set.  Note:  Q:X=\"\"  on kill side of \"ALK2\" xref is because deleting an entry        using ^DIK may set this field to NULL via a TRIGGER. ",
      "fieldNumber_": .04
    },
    {
      "fieldNumber": .05,
      "fieldName": "MERGE STATUS",
      "dataType": "SET",
      "rawType": "*S",
      "required": false,
      "setOfCodes": "0:NOT READY;1:READY;2:MERGED;3:IN PROGRESS;",
      "helpText": "This field is set when a duplicate record pair is verified as a duplicate. The actual merge will not occur until this field is set to READY (1).  The merge routine will set this field to MERGED (2).  Once set to MERGED (2) this field cannot be modified.  Note:  Kill side of \"AFR\" and \"ATO\" xref kill all possible combinations of        xref because deleting an entry in this file using ^DIK results in        the .04 field being NULL when these xrefs are fired. ",
      "fieldNumber_": .05
    },
    {
      "fieldNumber": .06,
      "fieldName": "DATE FOUND",
      "dataType": "DATE",
      "rawType": "RD",
      "required": true,
      "helpText": "This field indicates the date this duplicate record pair was added to this file. ",
      "fieldNumber_": .06
    },
    {
      "fieldNumber": .07,
      "fieldName": "DATE VERIFIED",
      "dataType": "DATE",
      "rawType": "DX",
      "required": false,
      "helpText": "This field contains the date this duplicate record pair was verified. The STATUS field must be set to \"N\" or \"V\" before data can be entered in this field. ",
      "fieldNumber_": .07
    },
    {
      "fieldNumber": .08,
      "fieldName": "DATE RESOLVED",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This field indicates the date this duplicate record pair was resolved. This field will be set by the dictionary when the STATUS field is set to \"N\" or the MERGE STATUS field is set to MERGED. ",
      "fieldNumber_": .08
    },
    {
      "fieldNumber": .09,
      "fieldName": "WHO CREATED",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "This field contains the user who created this entry.  If the entry was created by software this field will be NULL. ",
      "fieldNumber_": .09
    },
    {
      "fieldNumber": .1,
      "fieldName": "VERIF STARTED DATE",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date on which the status changed from POTENTIAL DUPLICATE to VERIFICATION IN PROGRESS. ",
      "fieldNumber_": .1
    },
    {
      "fieldNumber": .11,
      "fieldName": "WHO VERIFIED",
      "dataType": "POINTER",
      "rawType": "P200'X",
      "required": false,
      "pointerTo": 200,
      "helpText": "This field indicates the user who verified this duplicate record pair. The STATUS must be set to \"N\" or \"V\" before data can be entered in this field. ",
      "fieldNumber_": .11
    },
    {
      "fieldNumber": .12,
      "fieldName": "WHO CHANGED",
      "dataType": "POINTER",
      "rawType": "P200'I",
      "required": false,
      "pointerTo": 200,
      "helpText": "This field is set when the STATUS field is changed from \"V\" to any other value.  The reason this is so important is other packages have been notified and may have already done the merge. ",
      "fieldNumber_": .12
    },
    {
      "fieldNumber": .13,
      "fieldName": "APPROVED FOR BACK UP",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "0:NO;1:YES;",
      "helpText": "This field is used to document that a backup of the records has been generated.  This is required prior to merging the records. ",
      "fieldNumber_": .13
    },
    {
      "fieldNumber": .14,
      "fieldName": "BACKUP INDICATED BY",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This field is used to document the user who indicates that the backup has been generated and/or the fact that the backup was generated by the duplicate merge system. ",
      "fieldNumber_": .14
    },
    {
      "fieldNumber": .15,
      "fieldName": "DC TOTAL POSSIBLE SCORE",
      "dataType": "NUMERIC",
      "rawType": "NJ2,0",
      "length": 2,
      "required": false,
      "helpText": " This is the maximum possible score if this entry matches exactly to its couterpart. ",
      "fieldNumber_": .15
    },
    {
      "fieldNumber": .16,
      "fieldName": "DC VERIFIED DUPE THRESHOLD %",
      "dataType": "NUMERIC",
      "rawType": "NJ3,0",
      "length": 3,
      "required": false,
      "helpText": " This is the lowest % possible that will mark this entry as 'verified duplicate'. ",
      "fieldNumber_": .16
    },
    {
      "fieldNumber": .17,
      "fieldName": "DC POTENTIAL DUPE THRESHOLD %",
      "dataType": "NUMERIC",
      "rawType": "NJ3,0",
      "length": 3,
      "required": false,
      "helpText": " This is the lowest possible % of the total duplicate score that would mark this entry as 'potential duplicate/unverified'. ",
      "fieldNumber_": .17
    },
    {
      "fieldNumber": .18,
      "fieldName": "DC DUPE MATCH SCORE",
      "dataType": "NUMERIC",
      "rawType": "NJ3,0",
      "length": 3,
      "required": false,
      "helpText": " Actual duplicate score computed. ",
      "fieldNumber_": .18
    },
    {
      "fieldNumber": .19,
      "fieldName": "DC DUPE MATCH PERCENTILE",
      "dataType": "NUMERIC",
      "rawType": "NJ3,0",
      "length": 3,
      "required": false,
      "helpText": " This is the % of the total possible match score. ",
      "fieldNumber_": .19
    },
    {
      "fieldNumber": .2,
      "fieldName": "MERGE PROCESS",
      "dataType": "POINTER",
      "rawType": "P15.2'",
      "required": false,
      "pointerTo": 15.2,
      "helpText": "This field indicates which entry is the XDR MERGE PROCESS file this entry is associated with.  The merge process contains information on the status of the merge of the duplicate pair(s) included within the given process and the extent of completion. ",
      "fieldNumber_": .2
