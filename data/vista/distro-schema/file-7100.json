{
  "fileNumber": 7100,
  "fileName": "NOIS CALL",
  "globalRoot": "7100I",
  "globalReference": "^FSCD(\"CALL\",",
  "ddAccess": "N",
  "securityAudit": "",
  "fields": [
    {
      "fieldNumber": .01,
      "fieldName": "REFERENCE NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This field contains a mumps code generated unique name.  The unique name  is of the form UUU-YYMM-Nnnnn.  The characters UUU represent an abbreviation from the NOIS site file. The characters YY repersent the calander year in which the call was logged. The characters MM repersent the calander month in which the call was logged. The character N represent an abbreviation of the office for the site. The characters nnnn are just an incremental counter. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": 1,
      "fieldName": "SUBJECT",
      "dataType": "FREE-TEXT",
      "rawType": "RFX",
      "required": true,
      "helpText": "This field should be a brief description of the problem, between 1 and 60 characters.  The information in this field should be somewhat meaningful on it's own, as the subject will be displayed on all NOIS call list screens and is searchable for key words.  Qutotation marks are not allowed. ",
      "fieldNumber_": 1
    },
    {
      "fieldNumber": 1.5,
      "fieldName": "KEYWORDS",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This field contains free-text keywords used to categorize the call. Multiple keywords should be separated with commas. ",
      "fieldNumber_": 1.5
    },
    {
      "fieldNumber": 1.7,
      "fieldName": "WEB LINK",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "Enter a web link (URL) on this call. ",
      "fieldNumber_": 1.7
    },
    {
      "fieldNumber": 2,
      "fieldName": "REPORTING SITE",
      "dataType": "POINTER",
      "rawType": "RP7105.1",
      "required": true,
      "pointerTo": 7105.1,
      "helpText": "This field is a pointer to a file that holds the names of all locations which can report problems through NOIS. ",
      "fieldNumber_": 2
    },
    {
      "fieldNumber": 2.1,
      "fieldName": "PRIMARY SITE CONTACT",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "This field is a pointer to the NEW PERSON file.  The entry here should reflect the person that is normally a point of contact for problems for the location in field #2 'Reporting Location'. ",
      "fieldNumber_": 2.1
    },
    {
      "fieldNumber": 2.2,
      "fieldName": "PHONE NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This field should hold the phone number of the person named in field #2.1 'Primary Site Contact'. ",
      "fieldNumber_": 2.2
    },
    {
      "fieldNumber": 2.3,
      "fieldName": "SUPPORTING OFFICE",
      "dataType": "POINTER",
      "rawType": "P7105.3'",
      "required": false,
      "pointerTo": 7105.3,
      "helpText": "This field is the office that is responsible for Support Services to the reporting location. ",
      "fieldNumber_": 2.3
    },
    {
      "fieldNumber": 2.4,
      "fieldName": "DEVELOPING OFFICE",
      "dataType": "POINTER",
      "rawType": "P7105.3'",
      "required": false,
      "pointerTo": 7105.3,
      "helpText": "This field is the office which has the primary developemnt responsibilities for the package or module being reported. ",
      "fieldNumber_": 2.4
    },
    {
      "fieldNumber": 2.55,
      "fieldName": "SPECIALIST OFFICE",
      "dataType": "POINTER",
      "rawType": "P7105.3'",
      "required": false,
      "pointerTo": 7105.3,
      "helpText": "This field is the office of the primary specialist. ",
      "fieldNumber_": 2.55
    },
    {
      "fieldNumber": 2.6,
      "fieldName": "REOPENED",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This field is the date the call was reopened.  It is overwritten any time a call is changed from cancelled or closed to open. ",
      "fieldNumber_": 2.6
    },
    {
      "fieldNumber": 2.7,
      "fieldName": "LOCATION TYPE",
      "dataType": "POINTER",
      "rawType": "P7105.7'",
      "required": false,
      "pointerTo": 7105.7,
      "helpText": "This field is the location type for the reporting site. ",
      "fieldNumber_": 2.7
    },
    {
      "fieldNumber": 2.8,
      "fieldName": "VISN",
      "dataType": "POINTER",
      "rawType": "P7106.6'",
      "required": false,
      "pointerTo": 7106.6,
      "helpText": "This is the VISN for the reporting location. For local implementations of NOIS, this may be used as a location group. ",
      "fieldNumber_": 2.8
    },
    {
      "fieldNumber": 2.9,
      "fieldName": "SYSTEM",
      "dataType": "POINTER",
      "rawType": "P7106.7'",
      "required": false,
      "pointerTo": 7106.7,
      "helpText": "This is the system used at the reporting location. For local implementations of NOIS, this may be used to group the location. ",
      "fieldNumber_": 2.9
    },
    {
      "fieldNumber": 3,
      "fieldName": "MODULE/VERSION",
      "dataType": "POINTER",
      "rawType": "*P7105.4'",
      "required": false,
      "pointerTo": 7105.4,
      "helpText": "This field is the DHCP package and version reported in the NOIS call. It can also be a problem category that is not distributed as a DHCP package (ex. hardware, operating system or communication software). ",
      "fieldNumber_": 3
    },
    {
      "fieldNumber": 3.1,
      "fieldName": "PACKAGE",
      "dataType": "POINTER",
      "rawType": "P7105.5'",
      "required": false,
      "pointerTo": 7105.5,
      "helpText": "This field is the DHCP package reported in the NOIS call. ",
      "fieldNumber_": 3.1
    },
    {
      "fieldNumber": 3.2,
      "fieldName": "SUBCOMPONENT",
      "dataType": "POINTER",
      "rawType": "*P7105.6'",
      "required": false,
      "pointerTo": 7105.6,
      "helpText": "This field is a package subcomponent.  It made be added to a NOIS entry for developers to track the call.  It can also be used as a means to triage a call from a national support person to a development team. ",
      "fieldNumber_": 3.2
    },
    {
      "fieldNumber": 3.3,
      "fieldName": "PACKAGE GROUP",
      "dataType": "POINTER",
      "rawType": "P7105.8'",
      "required": false,
      "pointerTo": 7105.8,
      "helpText": "This field is the package group associated with the package field. ",
      "fieldNumber_": 3.3
    },
    {
      "fieldNumber": 4,
      "fieldName": "STATUS",
      "dataType": "POINTER",
      "rawType": "R*P7106.1'",
      "required": true,
      "pointerTo": 7106.1,
      "helpText": "This field is the support status of the NOIS call. ",
      "fieldNumber_": 4
    },
    {
      "fieldNumber": 4.1,
      "fieldName": "REFERRAL STATUS",
      "dataType": "POINTER",
      "rawType": "*P7106.1'",
      "required": false,
      "pointerTo": 7106.1,
      "helpText": "This field is the referal status status of the NOIS call. ",
      "fieldNumber_": 4.1
    },
    {
      "fieldNumber": 4.2,
      "fieldName": "AGE OF CALL",
      "dataType": "NUMERIC",
      "rawType": "NJ5,0",
      "length": 5,
      "required": false,
      "helpText": "This field is the the number of days since the call was reported. ",
      "fieldNumber_": 4.2
    },
    {
      "fieldNumber": 4.3,
      "fieldName": "AGE SINCE LAST EDIT",
      "dataType": "NUMERIC",
      "rawType": "NJ5,0",
      "length": 5,
      "required": false,
      "helpText": "This field is the number of days since the call was last edited. ",
      "fieldNumber_": 4.3
    },
    {
      "fieldNumber": 4.4,
      "fieldName": "AGE SINCE LAST STATUS",
      "dataType": "NUMERIC",
      "rawType": "NJ5,0",
      "length": 5,
      "required": false,
      "helpText": "This field is the number of days since the last status change for this call. ",
      "fieldNumber_": 4.4
    },
    {
      "fieldNumber": 4.5,
      "fieldName": "CURRENT STATUS",
      "dataType": "POINTER",
      "rawType": "P7106.1'",
      "required": false,
      "pointerTo": 7106.1,
      "helpText": "This field is the current status of the call.  This status is composed by the values of the status and referal status. This field is used for tracking status changes. ",
      "fieldNumber_": 4.5
    },
    {
      "fieldNumber": 4.6,
      "fieldName": "PREVIOUS STATUS",
      "dataType": "POINTER",
      "rawType": "P7106.1'",
      "required": false,
      "pointerTo": 7106.1,
      "helpText": "This field is the previous value of the current status.  This field is used for tracking status changes. ",
      "fieldNumber_": 4.6
    },
    {
      "fieldNumber": 4.7,
      "fieldName": "RTD IN DATE",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date the call was last referred. ",
      "fieldNumber_": 4.7
    },
    {
      "fieldNumber": 4.8,
      "fieldName": "RTD OUT DATE",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This the date the call was last unreferred. ",
      "fieldNumber_": 4.8
    },
    {
      "fieldNumber": 4.9,
      "fieldName": "RTD REREF DATE",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This field is the date the call was re-referred.  It is updated by the software (it's not editable) when a call is referred that was previously referred and then changed to not being referred. It is overwritten any time this occurs. ",
      "fieldNumber_": 4.9
    },
    {
      "fieldNumber": 5,
      "fieldName": "PRIMARY SPECIALIST",
      "dataType": "POINTER",
      "rawType": "*P7105.2'",
      "required": false,
      "pointerTo": 7105.2,
      "helpText": "This is the NOIS specialist for the call. ",
      "fieldNumber_": 5
    },
    {
      "fieldNumber": 5.1,
      "fieldName": "REFERRAL SPECIALIST",
      "dataType": "POINTER",
      "rawType": "*P7105.2'",
      "required": false,
      "pointerTo": 7105.2,
      "helpText": "This field can be used to enter a NOIS Specialist working on a referal issue on this call. ",
      "fieldNumber_": 5.1
    },
    {
      "fieldNumber": 5.2,
      "fieldName": "ENTRY PERSON",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "This is the person who entered the call. ",
      "fieldNumber_": 5.2
    },
    {
      "fieldNumber": 5.3,
      "fieldName": "ENTRY PERSON TYPE",
      "dataType": "POINTER",
      "rawType": "P7106.8'",
      "required": false,
      "pointerTo": 7106.8,
      "helpText": "This is the type of person who entered the call. ",
      "fieldNumber_": 5.3
    },
    {
      "fieldNumber": 6,
      "fieldName": "PRIORITY",
      "dataType": "POINTER",
      "rawType": "*P7106.2'X",
      "required": false,
      "pointerTo": 7106.2,
      "helpText": "This field is the priority of the NOIS call. Please use the telephone to report any URGENT or STAT situation. ",
      "fieldNumber_": 6
    },
    {
      "fieldNumber": 7,
      "fieldName": "PATCH",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This field can be used to associate a patch with this call. ",
      "fieldNumber_": 7
    },
    {
      "fieldNumber": 8,
      "fieldName": "FUNCTIONAL AREA",
      "dataType": "POINTER",
      "rawType": "*P7106.4'",
      "required": false,
      "pointerTo": 7106.4,
      "helpText": "This field is the functional area associated with the NOIS call. ",
      "fieldNumber_": 8
    },
    {
      "fieldNumber": 9,
      "fieldName": "PERFORMED TASK",
      "dataType": "POINTER",
      "rawType": "*P7106.3'",
      "required": false,
      "pointerTo": 7106.3,
      "helpText": "This field is the task associated with the NOIS call. ",
      "fieldNumber_": 9
    },
    {
      "fieldNumber": 10,
      "fieldName": "DATE CALL RECEIVED",
      "dataType": "DATE",
      "rawType": "RD",
      "required": true,
      "helpText": "Enter the date that the problem was reported.  Depending on how business  is done at your site this may be todays date or if you transcribe  problems this is the date the problem call was taken. ",
      "fieldNumber_": 10
    },
    {
      "fieldNumber": 20,
      "fieldName": "HOURS (TOTAL)",
      "dataType": "NUMERIC",
      "rawType": "NJ7,2",
      "length": 7,
      "required": false,
      "helpText": "This field is the number of hours associated with the NOIS call.  This field is updated by the NOIS editing programs. ",
      "fieldNumber_": 20
    },
    {
      "fieldNumber": 30,
      "fieldName": "SUPPORT REQUEST DESCRIPTION",
      "dataType": "SUBFILE",
      "rawType": "7100.01",
      "required": false,
      "helpText": "This is the description of the problem for the NOIS call. ",
      "isMultiple": true,
      "subFileNumber": 7100.01,
      "fieldNumber_": 30
    },
    {
      "fieldNumber": 50,
      "fieldName": "NOTES",
      "dataType": "SUBFILE",
      "rawType": "7100.02",
      "required": false,
      "helpText": "This is an ongoing dialog about the NOIS call.  Responses are appended to this field. ",
      "isMultiple": true,
      "subFileNumber": 7100.02,
      "fieldNumber_": 50
    },
    {
      "fieldNumber": 51,
      "fieldName": "FIRST LINE OF LAST NOTE",
      "dataType": "NUMERIC",
      "rawType": "NJ5,0",
      "length": 5,
      "required": false,
      "helpText": "This field holds the line number of the first line of the last note. This is used to display the beginnig of the last note on NOIS displays. ",
      "fieldNumber_": 51
    },
    {
      "fieldNumber": 52,
      "fieldName": "NOTE RESPONSE NUMBER",
      "dataType": "NUMERIC",
      "rawType": "NJ5,0",
      "length": 5,
      "required": false,
      "helpText": "This field is used as a counter for the number of responses appended to the NOTES field. ",
      "fieldNumber_": 52
    },
    {
      "fieldNumber": 80,
      "fieldName": "RESOLUTION SUMMARY",
      "dataType": "SUBFILE",
      "rawType": "7100.03",
      "required": false,
      "helpText": "This is a summary of what resolved the NOIS call. ",
      "isMultiple": true,
      "subFileNumber": 7100.03,
      "fieldNumber_": 80
    },
    {
      "fieldNumber": 81,
      "fieldName": "CLOSING PERSON",
      "dataType": "POINTER",
      "rawType": "P7105.2'",
      "required": false,
      "pointerTo": 7105.2,
      "helpText": "This is NOIS specialist closing the NOIS call. ",
      "fieldNumber_": 81
    },
    {
      "fieldNumber": 82,
      "fieldName": "DATE CALL CLOSED",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date the call was closed. ",
      "fieldNumber_": 82
    },
    {
      "fieldNumber": 100,
      "fieldName": "AUDIT HISTORY",
      "dataType": "SUBFILE",
      "rawType": "7100.04",
      "required": false,
      "helpText": "This is a description of any edits made to the NOIS call.  This does not include status changes or new entries. ",
      "isMultiple": true,
      "subFileNumber": 7100.04,
      "fieldNumber_": 100
    },
    {
      "fieldNumber": 101,
      "fieldName": "PRIMARY CALL",
      "dataType": "POINTER",
      "rawType": "P7100'",
      "required": false,
      "pointerTo": 7100,
      "helpText": "This is the primary call for this call. ",
      "fieldNumber_": 101
    },
    {
      "fieldNumber": 102,
      "fieldName": "DUPLICATE TO",
      "dataType": "POINTER",
      "rawType": "P7100'",
      "required": false,
      "pointerTo": 7100,
      "helpText": "This is a duplicate that this call is associated with. ",
      "fieldNumber_": 102
    },
    {
      "fieldNumber": 103,
      "fieldName": "DUPLICATE HISTORY",
      "dataType": "SUBFILE",
      "rawType": "7100.0103",
      "required": false,
      "isMultiple": true,
      "subFileNumber": 7100.0103,
      "fieldNumber_": 103
    },
    {
      "fieldNumber": 110,
      "fieldName": "STATUS HISTORY",
      "dataType": "SUBFILE",
      "rawType": "7100.05",
      "required": false,
      "helpText": "This is a history of status changes made to the call. ",
      "isMultiple": true,
      "subFileNumber": 7100.05,
      "fieldNumber_": 110
    },
    {
      "fieldNumber": 120,
      "fieldName": "RECEIPT TIMESTAMP",
      "dataType": "DATE",
      "rawType": "RD",
      "required": true,
      "helpText": "This is a timestamp of when the call was logged into the NOIS system,  this field and field 10 may not be the same. ",
      "fieldNumber_": 120
    },
    {
      "fieldNumber": 121,
      "fieldName": "STATUS CHANGE TIMESTAMP",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date/time of the last status change. ",
      "fieldNumber_": 121
    },
    {
      "fieldNumber": 122,
      "fieldName": "**CLOSE TIMESTAMP",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date/time when the call was last closed. ",
      "fieldNumber_": 122
    },
    {
      "fieldNumber": 123,
      "fieldName": "EDITED TIMESTAMP",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This the date/time when the call was last edited. ",
      "fieldNumber_": 123
    },
    {
      "fieldNumber": 124,
      "fieldName": "LAST EDITED BY",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "This is the NOIS specialist or person last editing the call. ",
      "fieldNumber_": 124
    },
    {
      "fieldNumber": 125,
      "fieldName": "PICKUP TIMESTAMP",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date/time when a specialist for the call was first entered. ",
      "fieldNumber_": 125
    },
    {
      "fieldNumber": 126,
      "fieldName": "PICKUP TIME",
      "dataType": "NUMERIC",
      "rawType": "NJ7,0",
      "length": 7,
      "required": false,
      "helpText": "This is the number of minutes between when the call was first logged to when a pickup timestamp was recorded. ",
      "fieldNumber_": 126
    }
