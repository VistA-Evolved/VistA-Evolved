    },
    {
      "fieldNumber": 104,
      "fieldName": "FAIR MARKET VALUE",
      "dataType": "NUMERIC",
      "rawType": "NJ11,2",
      "length": 11,
      "required": false,
      "helpText": "The estimated, realistic dollar value of an asset when categorized as \"VA Excess\" personal property. This value will replace the current TOTAL ASSET VALUE in the Equipment Inv. file. Note that the current TOTAL ASSET VALUE will automatically be saved as the ORIGINAL ASSET VALUE.   VA Accounting Standards require capitalized nonexpendable property to be recorded in the \"Excess\" Standard General Ledger (SGL) 1995 at its \"Expected Net Realizable Value\". ",
      "fieldNumber_": 104
    },
    {
      "fieldNumber": 301,
      "fieldName": "A.V. DATE",
      "dataType": "DATE",
      "rawType": "DI",
      "required": false,
      "helpText": "This field contains the date/time when an Adjustment Voucher was created. If blank, then an Adjustment Voucher has not yet been created for the FD Document. An Adjustment Voucher is used to notify Fiscal about a selected FAP Document. ",
      "fieldNumber_": 301
