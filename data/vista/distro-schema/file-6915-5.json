      "fieldName": "ASSET VALUE",
      "dataType": "NUMERIC",
      "rawType": "NJ14,2",
      "length": 14,
      "required": false,
      "helpText": "Asset value at time of document generation. ",
      "fieldNumber_": 101
    },
    {
      "fieldNumber": 102,
      "fieldName": "DISPOSITION DATE",
      "dataType": "DATE",
      "rawType": "RDX",
      "required": true,
      "helpText": "Disposition date in FAP format is extracted from this field. ",
      "fieldNumber_": 102
    },
    {
      "fieldNumber": 103,
