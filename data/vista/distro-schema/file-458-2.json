      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "A pointer to the NEW PERSON file (#200) which identifies the person who approves the request. ",
      "fieldNumber_": 21
    },
    {
      "fieldNumber": 22,
      "fieldName": "APPR. DATE/TIME",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "The date and time the request was approved. ",
      "fieldNumber_": 22
    },
