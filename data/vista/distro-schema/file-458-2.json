      "fieldName": "SUPR. COMMENT",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "A free text response for any comments the supervisor would like to enter concerning this request. ",
      "fieldNumber_": 20
    },
    {
