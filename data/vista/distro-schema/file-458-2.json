      "fieldNumber_": 18
    },
    {
      "fieldNumber": 19,
      "fieldName": "SUPR. ES",
      "dataType": "FREE-TEXT",
      "rawType": "FO",
      "required": false,
      "helpText": "The supervisor's electronic siganture code. ",
      "fieldNumber_": 19
    },
    {
