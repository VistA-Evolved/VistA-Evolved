      "fieldName": "RE-TRANSMISION ATTEMPTS",
      "dataType": "NUMERIC",
      "rawType": "NJ2,0",
      "length": 2,
      "required": false,
      "helpText": "Enter the number of times to re-try sending a message.  The default is 5 tries if this field is left blank. If a single message exceeds this value an Alert is sent to the HL7 mail group and the link is shutdown. ",
      "fieldNumber_": 200.02
    },
