      "fieldNumber_": 2
    },
    {
      "fieldNumber": 3,
      "fieldName": "AUTHORIZATION FROM DATE",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date that is entered in the 'Authorization From Date' field during the request/notification process. ",
      "fieldNumber_": 3
    },
    {
      "fieldNumber": 3.5,
      "fieldName": "DATE OF ADMISSION",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date that is entered in the 'Date of Admission' field during the request/notification process. ",
      "fieldNumber_": 3.5
    },
    {
      "fieldNumber": 4,
      "fieldName": "AUTHORIZATION TO DATE",
      "dataType": "DATE",
      "rawType": "RDX",
      "required": true,
      "helpText": "This is the date you determine the VA will no longer cover the veteran. ",
      "fieldNumber_": 4
    },
    {
      "fieldNumber": 4.5,
      "fieldName": "DATE OF DISCHARGE",
      "dataType": "DATE",
      "rawType": "DX",
      "required": false,
      "helpText": "This is the actual date of discharge. ",
      "fieldNumber_": 4.5
    },
    {
      "fieldNumber": 5,
      "fieldName": "AUTHORITY",
      "dataType": "POINTER",
      "rawType": "RP43.4'",
      "required": true,
      "pointerTo": 43.4,
      "helpText": "This field is the Admitting Authority used for the authorization. ",
      "fieldNumber_": 5
    },
    {
      "fieldNumber": 6,
      "fieldName": "ESTIMATED AMOUNT",
      "dataType": "NUMERIC",
      "rawType": "RNJ10,2",
      "length": 10,
      "required": true,
      "helpText": "This dollar amount is the best estimate of costs that will be incurred by the veteran. This dollar amount is passed to IFCAP. ",
      "fieldNumber_": 6
    },
    {
      "fieldNumber": 7,
      "fieldName": "AUTHORIZED SERVICES",
      "dataType": "SUBFILE",
      "rawType": "162.47",
      "required": false,
      "helpText": "This is a word processing field that should contain a statement similar to the following:  \"Hospitalization and Professional care necessary until the   patients condition is stabilized or improved enough to permit   transfer without hazard to a VA or other Federal facility for   continued treatment.\" or \"Hospitalization and Professional Care\". ",
      "isMultiple": true,
      "subFileNumber": 162.47,
      "fieldNumber_": 7
    },
    {
      "fieldNumber": 8,
      "fieldName": "USER ENTERING",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "This is the name of the user that enters the authorization. ",
      "fieldNumber_": 8
    },
    {
      "fieldNumber": 9,
      "fieldName": "STATUS",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "C:COMPLETE;I:INCOMPLETE;DC:CANCELLED;",
      "helpText": "The status of the 7078/authorization remains 'Incomplete' until a discharge date is entered. At that time the status is updated to complete and a corresponding authorization is built in file 161. ",
      "fieldNumber_": 9
    },
    {
      "fieldNumber": 10,
      "fieldName": "DATE OF ISSUE",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date the user sets up the 7078. ",
      "fieldNumber_": 10
    },
    {
      "fieldNumber": 12,
      "fieldName": "REASON FOR PENDING DISPOSITION",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:FOLLOW-UP/NOT STABLE;2:AWAITING DISCHARGE/TRANSFER;",
      "helpText": "If the status of a 7078 is Incomplete, that is the discharge date has not been entered, the user is prompted with this field. Once the status of the 7078 is Complete this field is set to null. ",
      "fieldNumber_": 12
    },
    {
      "fieldNumber": 15,
