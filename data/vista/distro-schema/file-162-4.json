      "fieldNumber_": .014
    },
    {
      "fieldNumber": .5,
      "fieldName": "FEE PROGRAM",
      "dataType": "POINTER",
      "rawType": "RP161.8'",
      "required": true,
      "pointerTo": 161.8,
      "helpText": "This field contains the valid Fee Program associated with this 7078, as defined in the Fee Basis Program file (i.e. Outpatient Medical, Contract Hospital, Community Nursing Home). ",
      "fieldNumber_": .5
    },
    {
      "fieldNumber": 1,
      "fieldName": "VENDOR",
