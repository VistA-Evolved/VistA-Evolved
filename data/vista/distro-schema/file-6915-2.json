  "fields": [
    {
      "fieldNumber": .01,
      "fieldName": "EQUIPMENT RECORD",
      "dataType": "POINTER",
      "rawType": "RP6914'",
      "required": true,
      "pointerTo": 6914,
      "helpText": "This field holds the internal entry number from file 6914 for the piece of capitalized NX equipment that an FA document was sent for. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": 1,
      "fieldName": "DATE/TIME CREATED",
      "dataType": "DATE",
      "rawType": "RD",
      "required": true,
      "helpText": "This is the date and time that the FA document was prepared. ",
      "fieldNumber_": 1
    },
    {
      "fieldNumber": 1.5,
      "fieldName": "SENDER",
      "dataType": "POINTER",
      "rawType": "RP200'",
      "required": true,
      "pointerTo": 200,
      "helpText": "This is the person who created the FA document using the Equipment Entry option. ",
      "fieldNumber_": 1.5
    },
    {
      "fieldNumber": 2,
      "fieldName": "SEGMENT 1 ID",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the Segment 1 ID for the FA document, usually it will be CTL. ",
      "fieldNumber_": 2
    },
    {
      "fieldNumber": 3,
      "fieldName": "SOURCE SYSTEM",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the source system for the FA document, ususally AMM. ",
      "fieldNumber_": 3
    },
    {
      "fieldNumber": 4,
      "fieldName": "DESTINATION SYSTEM",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the system where the FA document is going, usually FMS. ",
      "fieldNumber_": 4
    },
    {
      "fieldNumber": 5,
      "fieldName": "SUBMITTING STATION",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the station number of the site that is submitting this FA document. ",
      "fieldNumber_": 5
    },
    {
      "fieldNumber": 6,
      "fieldName": "TRANSACTION CLASS",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the class of document being sent to FMS.  It is usually DOC, to represent a document transaction. ",
      "fieldNumber_": 6
    },
    {
      "fieldNumber": 7,
      "fieldName": "TRANSACTION CODE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This tells FMS what kind of document is being sent.  FA for an FA document. ",
      "fieldNumber_": 7
    },
    {
      "fieldNumber": 8,
      "fieldName": "SEC1 CODE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the Security 1 code of the submitting Administration/Staff office. VHA=10, VBA=20, and NCS=40. ",
      "fieldNumber_": 8
    },
    {
      "fieldNumber": 9,
      "fieldName": "BATCH NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the batch number of the FA document being sent.  Currently set to six spaces. ",
      "fieldNumber_": 9
    },
    {
      "fieldNumber": 10,
      "fieldName": "TRANSACTION NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the transaction number for this FA document.  It consists of the station number_the last digit of the fiscal year_N_the 4 digit sequential number. ",
      "fieldNumber_": 10
    },
    {
      "fieldNumber": 11,
      "fieldName": "TRANSACTION DATE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the date the FA document was created in YYYYMMDD format. ",
      "fieldNumber_": 11
    },
    {
      "fieldNumber": 12,
      "fieldName": "TRANSACTION TIME",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the time the FA document was created in HHMMSS format. ",
      "fieldNumber_": 12
    },
    {
      "fieldNumber": 13,
      "fieldName": "SEQUENCE NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the transaction part sequence number.  Should always be 001. ",
      "fieldNumber_": 13
    },
    {
      "fieldNumber": 14,
      "fieldName": "SEQUENCE TOTAL",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the total number of transaction parts.  Should always be 001. ",
      "fieldNumber_": 14
    },
    {
      "fieldNumber": 15,
      "fieldName": "VERSION",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the AMES/MERS-FMS interface version.  Should always be 001. ",
      "fieldNumber_": 15
    },
    {
      "fieldNumber": 16,
      "fieldName": "SEGMENT 2 ID",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the segment identifier for segment 2.  Should always be DOC. ",
      "fieldNumber_": 16
    },
    {
      "fieldNumber": 20,
      "fieldName": "SEGMENT 3 ID",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the segment identifier for the the FA1 segmemnt.  Should always be FA1. ",
      "fieldNumber_": 20
    },
    {
      "fieldNumber": 21,
      "fieldName": "TRANS CODE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the Trans code for the FA1 segment.  Should always be FA. ",
      "fieldNumber_": 21
    },
    {
      "fieldNumber": 22,
      "fieldName": "TRANS DIVISION",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the Security 1 code.  VHA=10, VBA=20, NCS=40. ",
      "fieldNumber_": 22
    },
    {
      "fieldNumber": 23,
      "fieldName": "TRANS NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the transaction number for this FA document.  It consists of the station number_the last digit of the fiscal year_N_the 4 digit sequential number. ",
      "fieldNumber_": 23
    },
    {
      "fieldNumber": 24,
      "fieldName": "FIXED ASSET NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "The fixed asset number consists of the submitting station_the 2 digit satelite station number (or 2 spaces if no satellite)_the internal entry number of the asset from file 6914. ",
      "fieldNumber_": 24
    },
    {
      "fieldNumber": 25,
      "fieldName": "FIXED ASSET TYPE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the FA TYPE field from the NX SGL file for this particular Standard General Ledger account. ",
      "fieldNumber_": 25
    },
    {
      "fieldNumber": 26,
      "fieldName": "FA GROUP",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "The group is derived from the Category Stock Number.  It is generally the first 2 digits of the CSN concatenated with 00, except for CSNs in the 7nnn range, which send as 7000, except for 7020, 7021, 7025, 7035, 7040, & 7050, which transmit as themselves. ",
      "fieldNumber_": 26
    },
    {
      "fieldNumber": 27,
      "fieldName": "LOCATION",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "The location is derived from the first 2 digits of the CMR.  All are valid except 67, 73, 74, 79-85, and 87-98. ",
      "fieldNumber_": 27
