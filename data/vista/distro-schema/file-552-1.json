      "helpText": "This is the date/time when all entries in the data transmission were  marked processed. ",
      "fieldNumber_": 16
    },
    {
      "fieldNumber": 17,
      "fieldName": "LABELS PRINTED",
      "dataType": "DATE",
      "rawType": "552.117D",
