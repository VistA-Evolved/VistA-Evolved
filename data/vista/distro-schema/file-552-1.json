      "helpText": "  The date/time labels were printed by DHCP. ",
      "isMultiple": true,
      "subFileNumber": 552.117,
      "fieldNumber_": 17
    },
    {
      "fieldNumber": 18,
      "fieldName": "ACKNOWLEDGEMENT TEXT",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "  The general acknowledgement message for this data transmission. ",
      "fieldNumber_": 18
    },
    {
      "fieldNumber": 19,
      "fieldName": "PURGE STATUS",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:READY TO PURGE;2:PURGE COMPLETE;",
      "helpText": "  This status indicates the purge status for the transmission.  If the status equals 1, the transmission data in the files is ready to be purged.  If the status equals 2, the purge of the data has been completed. ",
      "fieldNumber_": 19
    },
    {
      "fieldNumber": 20,
      "fieldName": "PRIORITY",
      "dataType": "NUMERIC",
      "rawType": "NJ6,0",
      "length": 6,
      "required": false,
      "helpText": "This field is used to store the priority for download to the vendor. If no priority has been established or the transmission has been downloaded to the vendor, this field will be null. ",
      "fieldNumber_": 20
    },
    {
      "fieldNumber": 21,
      "fieldName": "CONTROLLED SUBSTANCE",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "0:Non-CS Transmission;1:CS Transmission;",
      "helpText": "A 1 indicates that this CMOP batch contains controlled substances. ",
      "fieldNumber_": 21
    }
