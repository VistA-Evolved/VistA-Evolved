  "fields": [
    {
      "fieldNumber": .01,
      "fieldName": "FACILITY BATCH REFERENCE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "The unique number which identifies this data transmission. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": 1,
      "fieldName": "STATUS",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:RECEIVED;2:QUEUED;3:PROCESSED;4:CLOSED;5:HOLD;6:PRINTED;99:REJECTED;7:PROCESSING;",
      "helpText": "The current status of this transmission.    Received   - Downloading to CMOP Database.    Queued     - Ready to transmit to vendor.    Processed  - Transmitted to vendor.    Closed     - All Rx's processed.    Hold       - Hold for review.    Printed    - Labels printed by DHCP.    Rejected   - Transmission rejected by vendor system.    Processing - Transmission is either downloading to the vendor system or                 labels are being printed on the DHCP system. ",
      "fieldNumber_": 1
    },
    {
      "fieldNumber": 2,
      "fieldName": "DIVISION",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "The outpatient pharmacy division responsible for this transmission. ",
      "fieldNumber_": 2
    },
    {
      "fieldNumber": 3,
      "fieldName": "SITE #",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "The site number of the outpatient pharmacy division responsible for this transmission. ",
      "fieldNumber_": 3
    },
    {
      "fieldNumber": 4,
      "fieldName": "SENDER",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "The individual responsible for this transmission. ",
      "fieldNumber_": 4
    },
    {
      "fieldNumber": 5,
      "fieldName": "TRANSMISSION DT/TM",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "The date/time the transmission was sent from the facility. ",
      "fieldNumber_": 5
    },
    {
      "fieldNumber": 6,
      "fieldName": "RECEIVED DT/TM",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "The date/time the transmission was received and downloaded into the  CMOP DATABASE file. ",
      "fieldNumber_": 6
    },
    {
      "fieldNumber": 7,
      "fieldName": "CLOSED DT/TM",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "The date/time all processing was completed for this transmission. ",
      "fieldNumber_": 7
    },
    {
      "fieldNumber": 8,
      "fieldName": "START SEQ #",
      "dataType": "NUMERIC",
      "rawType": "NJ10,0",
      "length": 10,
      "required": false,
      "helpText": "The beginning message number from the CMOP Rx Queue file.   ",
      "fieldNumber_": 8
    },
    {
      "fieldNumber": 9,
      "fieldName": "END SEQ #",
      "dataType": "NUMERIC",
      "rawType": "NJ10,0",
      "length": 10,
      "required": false,
      "helpText": "The ending message number from the facility's CMOP Rx Queue file.   ",
      "fieldNumber_": 9
    },
    {
      "fieldNumber": 10,
      "fieldName": "TOTAL ORDERS",
      "dataType": "NUMERIC",
      "rawType": "NJ10,0",
      "length": 10,
      "required": false,
      "helpText": "The total number of patient orders included in this transmission. ",
      "fieldNumber_": 10
    },
    {
      "fieldNumber": 11,
      "fieldName": "TOTAL RXS",
      "dataType": "NUMERIC",
      "rawType": "NJ10,0",
      "length": 10,
      "required": false,
      "helpText": "The total number of individual prescriptions included in this transmission. ",
      "fieldNumber_": 11
    },
    {
      "fieldNumber": 12,
      "fieldName": "RETRANSMISSION",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:YES;",
      "helpText": "A \"1\" indicates this is a retransmission of previously sent data. ",
      "fieldNumber_": 12
    },
    {
      "fieldNumber": 13,
      "fieldName": "BATCH REFERENCE",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "The facility-batch reference number of the original transmission. ",
      "fieldNumber_": 13
    },
    {
      "fieldNumber": 14,
      "fieldName": "SITE TEXT",
      "dataType": "SUBFILE",
      "rawType": "552.114A",
      "required": false,
      "helpText": "  The site specific information required for processing this transmission. ",
      "isMultiple": true,
      "subFileNumber": 552.114,
      "fieldNumber_": 14
    },
    {
      "fieldNumber": 15,
      "fieldName": "COMMENTS",
      "dataType": "SUBFILE",
      "rawType": "552.115",
      "required": false,
      "helpText": "Comments or notes regarding this transmission. ",
      "isMultiple": true,
      "subFileNumber": 552.115,
      "fieldNumber_": 15
    },
    {
