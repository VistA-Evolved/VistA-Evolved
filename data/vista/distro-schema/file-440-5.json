  "fields": [
    {
      "fieldNumber": .01,
      "fieldName": "PURCHASE CARD NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RFXI",
      "required": true,
      "helpText": "Please enter the purchase card number that you want to assign to a user. The number can not be an existing number assigned to and used by another user. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": 1,
      "fieldName": "FUND CONTROL POINT",
      "dataType": "FREE-TEXT",
      "rawType": "RFX",
      "required": true,
      "helpText": "Please input a Fund Control Point that you want all the purchases for this purchase card to be expensed to. ",
      "fieldNumber_": 1
    },
    {
      "fieldNumber": 2,
      "fieldName": "COST CENTER",
      "dataType": "FREE-TEXT",
      "rawType": "RFX",
      "required": true,
      "helpText": "Please input a valid Cost Center for the Fund Control POint. ",
      "fieldNumber_": 2
    },
    {
      "fieldNumber": 3,
      "fieldName": "BUDGET OBJECT CODE",
      "dataType": "FREE-TEXT",
      "rawType": "RFX",
      "required": true,
      "helpText": "Please input a valid Budget Object Code for the Cost Center. ",
      "fieldNumber_": 3
    },
    {
      "fieldNumber": 4,
      "fieldName": "PC USER SINGLE PURCHASE LIMIT",
      "dataType": "NUMERIC",
      "rawType": "NJ11,2",
      "length": 11,
      "required": false,
      "helpText": "This is the maximum amount that can be charged to this Purchase Card by the purchase card user for any one purchase. ",
      "fieldNumber_": 4
    },
    {
      "fieldNumber": 5,
      "fieldName": "MONTHLY PURCHASE LIMIT",
      "dataType": "NUMERIC",
      "rawType": "NJ12,2",
      "length": 12,
      "required": false,
      "helpText": "This is the maximum amount that can be charged to this Purchase  Card within any one month. ",
      "fieldNumber_": 5
    },
    {
      "fieldNumber": 6,
      "fieldName": "DELIVERY LOCATION",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the location that you want the ordered items to be delivered to most of the time. ",
      "fieldNumber_": 6
    },
    {
      "fieldNumber": 7,
      "fieldName": "CARD HOLDER",
      "dataType": "POINTER",
      "rawType": "RP200'",
      "required": true,
      "pointerTo": 200,
      "helpText": "This is the purchase card user this card is issued to. ",
      "fieldNumber_": 7
    },
    {
      "fieldNumber": 8,
      "fieldName": "APPROVING OFFICIAL",
      "dataType": "POINTER",
      "rawType": "RP200'",
      "required": true,
      "pointerTo": 200,
      "helpText": "Please input a user who can approve purchase card charges for this purchase card. ",
      "fieldNumber_": 8
    },
    {
      "fieldNumber": 9,
      "fieldName": "ALTERNATE APPROVING OFFICIAL",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "This is the user who can also approve purchase card charges for this card in case the Approving Official is not available. ",
      "fieldNumber_": 9
    },
    {
      "fieldNumber": 10,
      "fieldName": "PURCHASE CARD NAME",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the name by which the user will be able to recognize this purchase card. ",
      "fieldNumber_": 10
    },
    {
      "fieldNumber": 12,
      "fieldName": "SURROGATE USER",
      "dataType": "POINTER",
      "rawType": "440.512P",
      "required": false,
      "helpText": "This is the user who can also use this purchase card to order items. ",
      "fieldNumber_": 12
    },
    {
      "fieldNumber": 13,
      "fieldName": "MONTHLY PURCHASES",
      "dataType": "NUMERIC",
      "rawType": "NJ12,2",
      "length": 12,
      "required": false,
      "helpText": "This is a monthly purchase dollar amount. ",
      "fieldNumber_": 13
    },
    {
