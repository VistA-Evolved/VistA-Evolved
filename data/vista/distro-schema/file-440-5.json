      "fieldName": "INACTIVATE CARD?",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "Y:YES;N:NO;",
      "helpText": "This indicates if this purchase card is an inactive card. ",
      "fieldNumber_": 14
    },
    {
