      "fieldName": "IGNORE",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "0:Create error log;1:Ignore error log;",
      "helpText": "The value of this field is a flag that indicates whether or not an error log is to be produced. When the value of this field is false, an error log is created, otherwise the creation of the error log is ignored. ",
