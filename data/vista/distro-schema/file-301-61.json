      "pointerTo": 200,
      "helpText": "This field stores the user who added, or caused the entry to be added to the file. ",
      "fieldNumber_": 1.02
    },
    {
      "fieldNumber": 1.03,
      "fieldName": "DATE LAST UPDATED",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This field stores the date/time that the entry was last updated. ",
