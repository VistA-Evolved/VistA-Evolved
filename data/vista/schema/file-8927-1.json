      "fieldNumber": .17,
      "fieldName": "CONSULT LOCK",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "0:NO;1:YES;",
      "helpText": "This field is set by adding or removing TIU Templates to/from the TIU  TEMPLATE CONSULT LOCK parameter via the TIU TEMPLATE CONSULT LOCK option. Adding TIU Templates to that parameter will set the CONSULT LOCK value of TIU Template Fields to YES. This setting will prevent the template field from being editable in the GUI Template Field Editor. Removing a TIU Template from the parameter, will remove the Template Field's CONSULT LOCK value, thereby making the Template Field editable again. ",
      "fieldNumber_": .17
