      "fieldNumber": .01,
      "fieldName": "CPT CODE",
      "dataType": "FREE-TEXT",
      "rawType": "RFI",
      "required": true,
      "helpText": "This file contains both CPT from the AMA and HCFA. The AMA entries will have an internal number less than 99999. The AMA CPT are '5' numbers that coorespond to the internal number. The HCFA codes will have an internal number of 100000 or greater. These codes are '1' alpha followed by '4' numbers, which will NOT correspond to the internal number. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": 2,
      "fieldName": "SHORT NAME",
      "dataType": "FREE-TEXT",
      "rawType": "FX",
      "required": false,
      "helpText": "This field contains a short description of the CPT code. It must be  between 1 and 28 characters. ",
      "fieldNumber_": 2
    },
    {
      "fieldNumber": 3,
      "fieldName": "CPT CATEGORY",
      "dataType": "POINTER",
      "rawType": "*P81.1'",
      "required": false,
      "pointerTo": 81.1,
      "helpText": "This field contains the CPT Category associated with CPT Code.   It is a pointer to the CPT Category File. ",
      "fieldNumber_": 3
    },
    {
      "fieldNumber": 5,
      "fieldName": "INACTIVE FLAG",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:INACTIVE CODE;",
      "helpText": "This field is used to inactivate a CPT code. If this field contains a '1' then the code is inactive. During the annual update of the CPT file  no entries are deleted; they are inactivated by setting this flag. ",
      "fieldNumber_": 5
    },
