      "fieldName": "SEGMENT 2 ID",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the segment identifier for segment 2.  Should always be DOC. ",
      "fieldNumber_": 16
    },
    {
      "fieldNumber": 17,
      "fieldName": "SEGMENT 3 ID",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the segment identifier for the the FB1 segment.  Should always be FB1. ",
      "fieldNumber_": 17
    },
    {
      "fieldNumber": 18,
      "fieldName": "TRANS CODE",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the Trans code for the FB1 segment.  Should always be FB. ",
      "fieldNumber_": 18
    },
    {
      "fieldNumber": 19,
      "fieldName": "TRANS DIVISION",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the Security 1 code.  VHA=10, VBA=20, NCS=40. ",
      "fieldNumber_": 19
    },
    {
      "fieldNumber": 20,
      "fieldName": "TRANS NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the transaction number for this FB document.  It consists of the station number_the last digit of the fiscal year_N_the 4 digit sequential number. ",
      "fieldNumber_": 20
    },
    {
      "fieldNumber": 21,
      "fieldName": "FIXED ASSET NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "The fixed asset number consists of the submitting station_the 2 digit satelite station number (or 2 spaces if no satellite)_the internal entry number of the asset from file 6914. ",
      "fieldNumber_": 21
