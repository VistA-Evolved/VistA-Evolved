  "fields": [
    {
      "fieldNumber": .01,
      "fieldName": "EQUIPMENT RECORD",
      "dataType": "POINTER",
      "rawType": "RP6914'",
      "required": true,
      "pointerTo": 6914,
      "helpText": "This field holds the internal entry number from file 6914 for the piece of capitalized NX equipment that an FB document was sent for. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": 1,
      "fieldName": "DATE/TIME CREATED",
      "dataType": "DATE",
      "rawType": "RD",
      "required": true,
      "helpText": "This is the date and time that the FB document was prepared. ",
      "fieldNumber_": 1
    },
    {
      "fieldNumber": 1.5,
      "fieldName": "SENDER",
      "dataType": "POINTER",
      "rawType": "RP200'",
      "required": true,
      "pointerTo": 200,
      "helpText": "This is the person who created the FB document using the Betterment option. ",
      "fieldNumber_": 1.5
    },
    {
      "fieldNumber": 2,
      "fieldName": "SEGMENT 1 ID",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the Segment 1 ID for the FB document, usually it will be CTL. ",
      "fieldNumber_": 2
    },
    {
      "fieldNumber": 3,
      "fieldName": "SOURCE SYSTEM",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the source system for the FB document, ususally AMM. ",
      "fieldNumber_": 3
    },
    {
      "fieldNumber": 4,
      "fieldName": "DESTINATION SYSTEM",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the system where the FB document is going, usually FMS. ",
      "fieldNumber_": 4
    },
    {
      "fieldNumber": 5,
      "fieldName": "SUBMITTING STATION",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the station number of the site that is submitting this FB document. ",
      "fieldNumber_": 5
    },
    {
      "fieldNumber": 6,
      "fieldName": "TRANSACTION CLASS",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the class of document being sent to FMS.  It is usually DOC, to represent a document transaction. ",
      "fieldNumber_": 6
    },
    {
      "fieldNumber": 7,
      "fieldName": "TRANSACTION CODE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This tells FMS what kind of document is being sent.  FB for an FB document. ",
      "fieldNumber_": 7
    },
    {
      "fieldNumber": 8,
      "fieldName": "SEC1 CODE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the Security 1 code of the submitting Administration/Staff office. VHA=10, VBA=20, and NCS=40. ",
      "fieldNumber_": 8
    },
    {
      "fieldNumber": 9,
      "fieldName": "BATCH NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the batch number of the FB document being sent.  Currently set to six spaces. ",
      "fieldNumber_": 9
    },
    {
      "fieldNumber": 10,
      "fieldName": "TRANSACTION NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the transaction number for this FB document.  It consists of the station number_the last digit of the fiscal year_N_the 4 digit sequential number. ",
      "fieldNumber_": 10
    },
    {
      "fieldNumber": 11,
      "fieldName": "TRANSACTION DATE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the date the FB document was created in YYYYMMDD format. ",
      "fieldNumber_": 11
    },
    {
      "fieldNumber": 12,
      "fieldName": "TRANSACTION TIME",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the time the FB document was created in HHMMSS format. ",
      "fieldNumber_": 12
    },
    {
      "fieldNumber": 13,
      "fieldName": "SEQUENCE NUMBER",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the transaction part sequence number.  Should always be 001. ",
      "fieldNumber_": 13
    },
    {
      "fieldNumber": 14,
      "fieldName": "SEQUENCE TOTAL",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the total number of transaction parts.  Should always be 001. ",
      "fieldNumber_": 14
    },
    {
      "fieldNumber": 15,
      "fieldName": "VERSION",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the AMES/MERS-FMS interface version.  Should always be 001. ",
      "fieldNumber_": 15
