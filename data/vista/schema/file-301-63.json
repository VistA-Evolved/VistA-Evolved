      "fieldName": "HOST FILE NAME",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "This is the root name used for the host files created.  The extract may consist of multiple files, depending on the number of patients extracted. The files will be named <HOST FILE NAME> concatenated with '_1', '_2', etc. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": .02,
      "fieldName": "DIRECTORY",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "The directory/path for the host file. ",
      "fieldNumber_": .02
    },
    {
