      "fieldName": "DATE LAST PRINTED VIA MCS",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date that the associated claim was most recently printed by  the MCS option - Resubmit by Print. ",
      "fieldNumber_": .16
    },
