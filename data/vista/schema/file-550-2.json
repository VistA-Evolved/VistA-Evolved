      "length": 11,
      "required": true,
      "helpText": "This field contains the number of the data transmission. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": 1,
      "fieldName": "STATUS",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:CREATED;2:TRANSMITTED;3:ACKNOWLEDGED;4:CLOSED;5:RETRANSMITTED;",
      "helpText": "This is the status of the message. ",
      "fieldNumber_": 1
    },
    {
