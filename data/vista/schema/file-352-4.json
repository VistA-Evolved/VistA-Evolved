      "dataType": "DATE",
      "rawType": "RD",
      "required": true,
      "helpText": "This is the date on which billing for this clinic should be ignored or activated. ",
      "fieldNumber_": .02
    },
    {
      "fieldNumber": .03,
      "fieldName": "IGNORE MEANS TEST BILLING?",
      "dataType": "SET",
      "rawType": "RS",
      "required": true,
      "setOfCodes": "1:YES;0:NO;",
      "helpText": "This field is used to determine whether Means Test billing should be ignored or activated, as of the EFFECTIVE DATE (field #.02).   Please note that you only need an entry in this file for a clinic for which you would like Means Test billing to be IGNORED. ",
      "fieldNumber_": .03
