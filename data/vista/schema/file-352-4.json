      "required": false,
      "setOfCodes": "1:NO;0:YES;",
      "helpText": "Enter 'No' if the Third Party auto biller should NOT create bills for visits with this clinic.  This should only be set for clinics that are billable. ",
      "fieldNumber_": .06
    }
