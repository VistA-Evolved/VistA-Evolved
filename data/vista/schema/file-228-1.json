      "fieldNumber_": .15
    },
    {
      "fieldNumber": .16,
      "fieldName": "DAS DISPOSITION",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:In progress;2:Completed;3:Terminated;4:Maintenance;",
      "helpText": "This is the patient disposition for the encounter. ",
      "fieldNumber_": .16
    },
    {
      "fieldNumber": .17,
      "fieldName": "SPECIALTY",
      "dataType": "POINTER",
      "rawType": "P42.4'",
      "required": false,
      "pointerTo": 42.4,
      "helpText": "This is the bedsection of the inpatient at the time of the encounter.  It  is computer derived from the current Ward at the time of the dental  encounter.   This field replaces the old DENTAL BEDSECTION file which will be deleted  in FY2004. ",
      "fieldNumber_": .17
    },
    {
      "fieldNumber": .18,
      "fieldName": "DIVISION",
      "dataType": "POINTER",
      "rawType": "*P4'",
      "required": false,
      "pointerTo": 4,
      "helpText": "This is the division where this encounter occurred.   ",
      "fieldNumber_": .18
    },
    {
      "fieldNumber": .19,
      "fieldName": "FILED TO PCE",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:YES;0:NO;",
      "helpText": "If this value is yes then this record plus the associated transactions  were filed to PCE. ",
      "fieldNumber_": .19
    },
    {
      "fieldNumber": 1.01,
      "fieldName": "DATE DELETED",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "Enter that date that this record was deleted to indicate that it is no  longer part of the official medical record. ",
      "fieldNumber_": 1.01
    },
    {
