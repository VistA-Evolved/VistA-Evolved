  "fields": [
    {
      "fieldNumber": .01,
      "fieldName": "RECORD#",
      "dataType": "NUMERIC",
      "rawType": "RNJ8,0",
      "length": 8,
      "required": true,
      "helpText": "This is the number of the record.  It is just a unique place holder. Entries in this file are entered through the RPC broker call from the DSS-CPRS-Dental gui. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": .02,
      "fieldName": "PATIENT",
      "dataType": "POINTER",
      "rawType": "P2'",
      "required": false,
      "pointerTo": 2,
      "helpText": "This field has a C cross refernece on it for sorting the file by patient DFN. ",
      "fieldNumber_": .02
    },
    {
      "fieldNumber": .03,
      "fieldName": "DATE CREATED",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date that this record was created. ",
      "fieldNumber_": .03
    },
    {
      "fieldNumber": .04,
      "fieldName": "CREATOR",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "This is the person who created this record ",
      "fieldNumber_": .04
    },
    {
      "fieldNumber": .05,
      "fieldName": "VISIT",
      "dataType": "POINTER",
      "rawType": "P9000010'",
      "required": false,
      "pointerTo": 9000010,
      "helpText": "This contains the pointer for the Visit file entry that created this record. ",
      "fieldNumber_": .05
    },
    {
      "fieldNumber": .06,
      "fieldName": "DAS",
      "dataType": "POINTER",
      "rawType": "P221'",
      "required": false,
      "pointerTo": 221,
      "helpText": "This contains the pointer to the national Dental Activity System (DAS) record that was created by the DSS-DENTAL-CPRS application through this record. ",
      "fieldNumber_": .06
    },
    {
      "fieldNumber": .07,
      "fieldName": "PROVIDER",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "Enter the name of the provider that was responsible for this record and procedures. ",
      "fieldNumber_": .07
    },
    {
      "fieldNumber": .08,
      "fieldName": "DISTRIBUTED PROVIDER",
      "dataType": "POINTER",
      "rawType": "P200'",
      "required": false,
      "pointerTo": 200,
      "helpText": "This is the Provider who receives PCE credit when the entering provider  is a resident. ",
      "fieldNumber_": .08
    },
    {
      "fieldNumber": .09,
      "fieldName": "GROUP",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:YES;0:NO;",
      "helpText": "If this encounter was not related to an individual patient, but rather to a GROUP, then enter Yes for this field.  Entering NO is not required. ",
      "fieldNumber_": .09
    },
    {
      "fieldNumber": .1,
      "fieldName": "PATIENT TYPE",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "I:inpatient;O:outpatient;",
      "helpText": "This indicates the status of the patient at the time of the encounter. ",
      "fieldNumber_": .1
    },
    {
      "fieldNumber": .11,
      "fieldName": "LOCATION",
      "dataType": "POINTER",
      "rawType": "P44'",
      "required": false,
      "pointerTo": 44,
      "helpText": "This is the location that was selected (for filing to PCE) ",
      "fieldNumber_": .11
    },
    {
      "fieldNumber": .12,
      "fieldName": "OUTPATIENT ENCOUNTER",
      "dataType": "POINTER",
      "rawType": "P409.68'",
      "required": false,
      "pointerTo": 409.68,
      "helpText": "This pointer to the Outpatient Encounter field was requested by the  Decision Support System staff.  It cannot be provided at this time as a  change to the DATA2PCE^PXAPI utility must be made to support the  returning of outpatient encounter. ",
      "fieldNumber_": .12
    },
    {
