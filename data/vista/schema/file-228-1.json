      "fieldName": "DAS PATIENT CATEGORY",
      "dataType": "POINTER",
      "rawType": "P220.2'",
      "required": false,
      "pointerTo": 220.2,
      "helpText": "This is the patient category for this encounter that was filed to DAS ",
      "fieldNumber_": .13
    },
    {
      "fieldNumber": .14,
      "fieldName": "DAS BED SECTION",
      "dataType": "POINTER",
      "rawType": "P220.4'",
      "required": false,
      "pointerTo": 220.4,
      "helpText": "This is the bed section for this encounter that was filed to DAS ",
      "fieldNumber_": .14
    },
    {
      "fieldNumber": .15,
      "fieldName": "DAS DIVISION",
      "dataType": "POINTER",
      "rawType": "P225'",
      "required": false,
      "pointerTo": 225,
