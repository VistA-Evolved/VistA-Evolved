      "dataType": "NUMERIC",
      "rawType": "RNJ10,0",
      "length": 10,
      "required": true,
      "helpText": "The number of the batch for EDI transmissions. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": .02,
      "fieldName": "LATEST RECEIPT STATUS",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "P:PENDING AUSTIN RECEIPT;A0:RECEIVED IN AUSTIN;",
      "helpText": "This field indicates where the last receipt for this batch came from.  It is used in tracking how far a batch has gone in the transmission path for as long as it can be tracked with electronic receipt messages. ",
      "fieldNumber_": .02
    },
    {
      "fieldNumber": .03,
