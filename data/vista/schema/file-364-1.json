      "fieldName": "BATCH RESUBMIT TASK",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "If the batch is being resubmitted, this is the task # of the task that is doing the resubmission if the job is queued.  No entry is made here if the task is not queued. ",
      "fieldNumber_": .09
    },
