      "fieldName": "BATCH RESUBMIT INCOMPLETE",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "0:NO;1:YES;",
      "helpText": "This field is 0 or null if batch either was not resubmitted or if all bills in the batch have been resubmitted.  It is a 1 (YES) if any bills in the batch were not resubmitted, but the batch itself was. ",
      "fieldNumber_": .1
    },
