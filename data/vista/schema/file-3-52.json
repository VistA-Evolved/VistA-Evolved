      "fieldName": "DEVICE",
      "dataType": "POINTER",
      "rawType": "R*P3.5'I",
      "required": true,
      "pointerTo": 3.5,
      "helpText": "Identifies the device that the user selected when the print request was made.     ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": .02,
      "fieldName": "DT/TM HOST FILE CREATED",
      "dataType": "DATE",
      "rawType": "RD",
      "required": true,
      "helpText": "This is the date/time that the host file was created.    ",
      "fieldNumber_": .02
    },
    {
      "fieldNumber": .03,
      "fieldName": "DT/TM PASSED TO PRINT SERVER",
      "dataType": "DATE",
      "rawType": "RDI",
      "required": true,
      "helpText": "This is the date and time that the host file was passed to the print server. No value indicates that the file was not yet passed to the print server.   ",
      "fieldNumber_": .03
    },
    {
      "fieldNumber": .04,
      "fieldName": "OWNER",
      "dataType": "POINTER",
      "rawType": "RP200'I",
      "required": true,
      "pointerTo": 200,
      "helpText": "This field indicates the user that made the print request.    ",
      "fieldNumber_": .04
    },
    {
      "fieldNumber": .05,
      "fieldName": "OS PRINT QUEUE",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the name of the print queue that the print job should be submitted to. The print queue is created within the host operating system.   ",
      "fieldNumber_": .05
    },
    {
      "fieldNumber": .06,
      "fieldName": "HOST FILE",
      "dataType": "FREE-TEXT",
      "rawType": "RF",
      "required": true,
      "helpText": "The unique name of the host file. The name will have the following format:  PQ$JOB_<record IEN>.TXT   ",
      "fieldNumber_": .06
    },
    {
      "fieldNumber": .07,
      "fieldName": "STATUS",
      "dataType": "SET",
      "rawType": "RS",
      "required": true,
      "setOfCodes": "O:FILE OPENED;OE:ERROR OPENING FILE;AE:APPLICATION ERROR BEFORE CLOSING FILE;Q:PRINT JOB QUEUED;QE:ERROR SUBMITTING JOB TO QUEUE;P:FILE PRINTED, DELETED;D:FILE DELETED, NOT PRINTED;",
      "helpText": "The current status of the host file.    ",
      "fieldNumber_": .07
    },
    {
      "fieldNumber": .08,
      "fieldName": "OS JOB ID",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the identifier assigned by the OS to the print job.  The format is system dependent.   ",
      "fieldNumber_": .08
    },
    {
      "fieldNumber": .09,
      "fieldName": "HFS DIRECTORY",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "1:PRIMARY;2:SECONDARY;",
      "helpText": "This describes the system on which the print queue is located. This field is important in mixed OS environments.  The print queues and  host files are accessible only on the system that they were created on.   ",
      "fieldNumber_": .09
