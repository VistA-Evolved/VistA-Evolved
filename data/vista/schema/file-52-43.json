  "fields": [
    {
      "fieldNumber": .01,
      "fieldName": "PATIENT ICN",
      "dataType": "NUMERIC",
      "rawType": "RNJ12,0",
      "length": 12,
      "required": true,
      "helpText": "This is a machine-to-machine identifier for a patient. The number may  only be edited by MPI/PD. ",
      "fieldNumber_": .01
    },
    {
      "fieldNumber": 2,
      "fieldName": "PATIENT SSN",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the social security number associated with this patient. In  combination with the Integration Control Number, it is used to validate  the patient's identification. ",
      "fieldNumber_": 2
    },
    {
      "fieldNumber": 3,
      "fieldName": "RX #",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "This is the external representation of the prescription number for the refill to be processed. ",
      "fieldNumber_": 3
    },
    {
      "fieldNumber": 4,
      "fieldName": "INSTITUTION",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "The VA facility or institution that will be processing the refill for  this prescription. ",
      "fieldNumber_": 4
    },
    {
      "fieldNumber": 5,
      "fieldName": "DATE PROCESSED",
      "dataType": "DATE",
      "rawType": "D",
      "required": false,
      "helpText": "This is the date the pharmacy processed the refill request. ",
      "fieldNumber_": 5
    },
    {
      "fieldNumber": 6,
      "fieldName": "RESULT",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "0:NOT PROCESSED;1:FILLED;2:NOT FILLED;",
      "helpText": "The result of the pharmacy staff processing the refill request. The  result may be either FILLED or NOT FILLED. ",
      "fieldNumber_": 6
    },
    {
      "fieldNumber": 7,
      "fieldName": "MHEV UPDATE",
      "dataType": "SET",
      "rawType": "S",
      "required": false,
      "setOfCodes": "0:NO;1:YES;",
      "helpText": "Indicates whether or not a status update for this refill request has been  sent to the My HealtheVet system. ",
      "fieldNumber_": 7
    },
    {
      "fieldNumber": 8,
