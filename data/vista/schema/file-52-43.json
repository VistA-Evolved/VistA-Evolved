      "fieldNumber_": 8
    },
    {
      "fieldNumber": 9,
      "fieldName": "PATIENT",
      "dataType": "POINTER",
      "rawType": "RP2'",
      "required": true,
      "pointerTo": 2,
      "helpText": "The patient receiving treatment. ",
      "fieldNumber_": 9
    },
    {
      "fieldNumber": 10,
      "fieldName": "REMARKS",
      "dataType": "FREE-TEXT",
      "rawType": "F",
      "required": false,
      "helpText": "Refill # and suspended date if processed or the reason why it was not processed. ",
