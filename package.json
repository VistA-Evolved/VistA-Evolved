{
  "name": "vista-evolved",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=24 <25"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "ajv@<7": "6.14.0",
      "ajv@>=7 <9": "8.18.0",
      "@esbuild-kit/core-utils>esbuild": "0.25.0"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-26996"
      ]
    }
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "cprs:extract": "node tools/cprs-extract/run-all.mjs",
    "cprs:generate-stubs": "node tools/cprs-extract/generate-api-stubs.mjs",
    "qa:phase-replay": "pnpm -C apps/web playwright test e2e/phase-replay.spec.ts e2e/dead-click-crawler.spec.ts --reporter=list",
    "qa:smoke": "node scripts/qa-runner.mjs smoke",
    "qa:all": "node scripts/qa-runner.mjs all",
    "qa:api": "node scripts/qa-runner.mjs api",
    "qa:web": "node scripts/qa-runner.mjs web",
    "qa:security": "node scripts/qa-runner.mjs security",
    "qa:vista": "node scripts/qa-runner.mjs vista",
    "qa:prompts": "node scripts/qa-runner.mjs prompts",
    "qa:prod-posture": "node scripts/qa-runner.mjs prod-posture",
    "qa:phase": "node scripts/phase-qa-runner.mjs phase",
    "qa:range": "node scripts/phase-qa-runner.mjs range",
    "qa:phase-index": "node scripts/build-phase-index.mjs",
    "qa:phase-audit": "node scripts/qa-runner.mjs phase-audit",
    "qa:gauntlet:fast": "node qa/gauntlet/cli.mjs --suite fast",
    "qa:gauntlet:rc": "node qa/gauntlet/cli.mjs --suite rc",
    "qa:gauntlet:full": "node qa/gauntlet/cli.mjs --suite full",
    "qa:gauntlet:manifest": "node qa/gauntlet/build-manifest.mjs",
    "qa:phase-registry": "node scripts/qa/phase-registry.mjs",
    "qa:generate-tests": "node scripts/qa/generate-phase-tests.mjs",
    "qa:rpc-trace:verify": "node scripts/qa/rpc-trace-manager.mjs verify",
    "qa:rpc-trace:record": "node scripts/qa/rpc-trace-manager.mjs record",
    "audit:system": "node scripts/audit/system-audit.mjs"
  }
}
