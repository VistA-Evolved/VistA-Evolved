# =============================================================================
# VistA-Evolved — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env — it is gitignored.
# =============================================================================

# ---------- VistA EHR Connection ----------
# VistA RPC Broker credentials (WorldVistA Docker defaults on Docker Hub)
VISTA_ACCESS_CODE=your_access_code_here
VISTA_VERIFY_CODE=your_verify_code_here
VISTA_CONTEXT=OR CPRS GUI CHART

# VistA host port mappings (container-internal ports are fixed)
VISTA_BROKER_PORT=9210
VISTA_WEB_PORT=8001

# ---------- PostgreSQL ----------
POSTGRES_DB=vista_evolved
POSTGRES_USER=vista_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- API Server ----------
API_PORT=4000
STORE_BACKEND=pg
PLATFORM_PG_RLS_ENABLED=false

# ---------- Web Frontend ----------
WEB_PORT=5173
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------- Security ----------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
SESSION_COOKIE=ehr_session

# ---------- Logging ----------
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ---------- Audit ----------
AUDIT_SINK=memory
