{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vista-evolved.dev/schemas/release-manifest.v1.json",
  "title": "VistA Release Manifest",
  "description": "Machine-readable build provenance for VistA-Evolved releases. Generated by build-images.ps1 or emit-release-manifest.mjs.",
  "type": "object",
  "required": [
    "schemaVersion",
    "buildSha",
    "buildTime",
    "upstreamShas",
    "rpcCount",
    "images"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for forward compat."
    },
    "buildSha": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$",
      "description": "Short or full SHA of the VistA-Evolved commit."
    },
    "buildTime": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 build timestamp."
    },
    "builderVersion": {
      "type": "string",
      "description": "Version of the build tool (e.g., build-images.ps1 or emit-release-manifest.mjs)."
    },
    "upstreamShas": {
      "type": "object",
      "description": "Map of upstream repo name -> pinned commit SHA from LOCK.json.",
      "additionalProperties": {
        "type": ["string", "null"]
      }
    },
    "rpcCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of RPCs in rpcRegistry.ts RPC_REGISTRY."
    },
    "rpcExceptionCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of RPCs in rpcRegistry.ts RPC_EXCEPTIONS."
    },
    "routineCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of custom .m routines in services/vista/."
    },
    "images": {
      "type": "array",
      "description": "Docker images built in this release.",
      "items": {
        "type": "object",
        "required": ["name", "tag"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Image name (e.g., vista-evolved/api)."
          },
          "tag": {
            "type": "string",
            "description": "Image tag."
          },
          "digest": {
            "type": ["string", "null"],
            "description": "Image digest (sha256:...) if available."
          },
          "dockerfile": {
            "type": "string",
            "description": "Path to Dockerfile relative to repo root."
          }
        }
      }
    },
    "vistaDocker": {
      "type": "object",
      "description": "WorldVistA Docker image provenance.",
      "properties": {
        "image": {
          "type": "string",
          "description": "Docker image reference (e.g., worldvista/worldvista-ehr:latest)."
        },
        "digest": {
          "type": ["string", "null"],
          "description": "Image digest if pinned."
        }
      }
    },
    "customRoutines": {
      "type": "array",
      "description": "List of custom .m routine filenames.",
      "items": {
        "type": "string"
      }
    },
    "patchTrainLevel": {
      "type": ["string", "null"],
      "description": "Current patch train level if applicable (e.g., 'candidate-2025-01')."
    }
  },
  "additionalProperties": false
}
