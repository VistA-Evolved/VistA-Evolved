# -------------------------------------------------------------------
# VistA Distro Lane -- Version Pinning
# -------------------------------------------------------------------
# This file pins versions for reproducible builds.
# Edit ONLY when intentionally upgrading a component.
# -------------------------------------------------------------------

# YottaDB base image version (GT.M-compatible MUMPS engine)
YOTTADB_VERSION=r2.02
YOTTADB_IMAGE=yottadb/yottadb-debian:r2.02

# VistA routine source -- WorldVistA-M repository
# Pinned to a specific commit for reproducible builds (Phase 288).
# To upgrade: update the commit hash, rebuild, and run verify-vista-compat.ps1.
VISTA_ROUTINE_SOURCE=https://github.com/WorldVistA/VistA-M.git
VISTA_ROUTINE_REF=610e07c

# VistA globals source (initial database load)
VISTA_GLOBALS_SOURCE=https://github.com/WorldVistA/VistA-M.git
VISTA_GLOBALS_REF=610e07c

# Build metadata
BUILD_DATE=
BUILD_SHA=
