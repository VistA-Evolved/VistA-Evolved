{
  "name": "@vista-evolved/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/telemetry/register.ts --env-file=.env.local src/index.ts",
    "start": "tsx --import ./src/telemetry/register.ts --env-file=.env.local src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "vitest run tests/contract.test.ts",
    "test:rpc": "vitest run tests/rpc-boundary.test.ts",
    "test:jobs": "vitest run tests/job-worker-smoke.test.ts",
    "worker": "tsx --env-file=.env.local src/jobs/worker-entrypoint.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-metrics": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@vista-evolved/locale-utils": "workspace:*",
    "@vista-evolved/shared-types": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.1",
    "graphile-worker": "^0.16.6",
    "ioredis": "^5.10.0",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "ssh2": "^1.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "@types/ssh2": "^1.15.5",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
