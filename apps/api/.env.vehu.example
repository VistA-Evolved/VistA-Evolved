# VEHU VistA Environment Configuration
# =====================================
# For use with worldvista/vehu Docker image (recommended dev/test baseline)
# Copy to .env.local and fill in values, or use scripts/dev/use-vehu-env.ps1
#
# See: https://hub.docker.com/r/worldvista/vehu

# -- VistA RPC Broker --
VISTA_HOST=127.0.0.1
VISTA_PORT=9431
VISTA_CONTEXT=OR CPRS GUI CHART

# -- VEHU Published Demo Credentials --
# These are published on Docker Hub and are NOT secret.
# For production, use OIDC instead.
VISTA_ACCESS_CODE=PRO1234
VISTA_VERIFY_CODE=PRO1234!!

# -- Instance identification --
VISTA_INSTANCE_ID=vehu-dev

# -- Optional: Debug logging --
# VISTA_DEBUG=true
