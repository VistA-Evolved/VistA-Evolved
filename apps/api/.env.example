# VistA RPC Broker connection (Phase 3+)
# Default: WorldVistA-EHR Docker on port 9430
# VEHU:    WorldVistA VEHU Docker on port 9431 (see .env.vehu.example)
VISTA_HOST=127.0.0.1
VISTA_PORT=9430

# VistA credentials (Phase 4A+)
# WorldVistA-EHR: PROV123 / PROV123!!  (Docker Hub published)
# VEHU:           PRO1234 / PRO1234!!  (Docker Hub published)
VISTA_ACCESS_CODE=
VISTA_VERIFY_CODE=

# Application context for RPC calls (default shown)
VISTA_CONTEXT=OR CPRS GUI CHART

# API server port (default 3001)
# PORT=3001
# HOST=127.0.0.1

# ---- Phase 16: Production config ----

# Build metadata (set by CI/CD or Docker build args)
# BUILD_SHA=abc123
# BUILD_TIME=2026-02-17T00:00:00Z

# Security
# ALLOWED_ORIGINS=https://ehr.example.com,https://ehr-staging.example.com
# SESSION_COOKIE=ehr_session
# SESSION_ABSOLUTE_TTL_MS=28800000
# SESSION_IDLE_TTL_MS=1800000

# Logging
# LOG_LEVEL=info
# LOG_FORMAT=json

# Audit
# AUDIT_SINK=memory
# AUDIT_FILE_PATH=logs/audit.jsonl
# AUDIT_MAX_ENTRIES=5000
# AUDIT_RETENTION_DAYS=365

# RPC resilience
# RPC_CALL_TIMEOUT_MS=15000
# RPC_CONNECT_TIMEOUT_MS=10000
# RPC_CB_THRESHOLD=5
# RPC_CB_RESET_MS=30000
# RPC_MAX_RETRIES=2
# RPC_RETRY_DELAY_MS=1000

# ---- RPC Connection Pool (Phase W42-P1) ----
# Per-tenant, per-DUZ authenticated connection pool
# VISTA_POOL_SIZE=3                       # Connections per user in pool
# VISTA_MAX_POOL_TOTAL=50                 # Max total connections across all users
# VISTA_MAX_CONNECTIONS_PER_USER=3        # Max connections for a single DUZ
# VISTA_POOL_IDLE_TIMEOUT_MS=300000       # Idle connection reap timeout (5 min)

# ---- Redis (Phase W42-P2) ----
# Optional. When set, Redis is used for sessions, rate limiting, distributed locks, and pub/sub.
# Without it, the API falls back to in-memory stores (single-instance only).
# Start Redis: docker compose -f docker-compose.prod.yml up redis -d
# REDIS_URL=redis://127.0.0.1:6379

# Cache
# CACHE_DEFAULT_TTL_MS=60000
# CACHE_DEMOGRAPHICS_TTL_MS=300000
# CACHE_LIST_TTL_MS=30000
# CACHE_MAX_ENTRIES=500

# Rate limiting
# RATE_LIMIT_GENERAL=200
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_LOGIN=10

# ---- Phase 141/153: Identity & Access Management ----
# AUTH_MODE controls the authentication mechanism.
# Values: "dev_local" (VistA RPC auth, default), "oidc" (enterprise SSO)
# rc/prod modes REQUIRE AUTH_MODE=oidc.
# AUTH_MODE=dev_local

# OIDC Configuration (required when AUTH_MODE=oidc or PLATFORM_RUNTIME_MODE=rc|prod)
# OIDC_ENABLED=true
# OIDC_ISSUER=http://localhost:8180/realms/vista-evolved
# OIDC_CLIENT_ID=vista-evolved-api
# OIDC_AUDIENCE=vista-evolved-api
# OIDC_JWKS_URI=  (auto-derived from OIDC_ISSUER if not set)

# Runtime mode: dev (default), test, rc, prod
# rc/prod enforce: Postgres required, OIDC required, RLS auto-enabled
# PLATFORM_RUNTIME_MODE=dev

# ---- Phase 101: Platform Database (Postgres) ----
# Set PLATFORM_PG_URL to enable Postgres as the platform store.
# Without it, SQLite (data/platform.db) remains the primary backend.
# Start Postgres: docker compose -f services/platform-db/docker-compose.yml up -d
# PLATFORM_PG_URL=postgresql://ve_api:ve_dev_only_change_in_prod@127.0.0.1:5433/ve_platform
# PLATFORM_PG_POOL_MIN=2
# PLATFORM_PG_POOL_MAX=10
# Phase 122: RLS auto-enables when PLATFORM_PG_URL + NODE_ENV=production.
# Set explicitly to override: true=always on, false=always off.
# PLATFORM_PG_RLS_ENABLED=false

# ---- Phase 22-24+156: Imaging (Orthanc + OHIF) ----
# Start imaging stack: cd services/imaging && docker compose --profile imaging up -d

# Orthanc DICOM server
# ORTHANC_URL=http://localhost:8042
# OHIF_URL=http://localhost:3003
# ORTHANC_DICOMWEB_ROOT=/dicom-web

# Proxy + cache
# IMAGING_PROXY_TIMEOUT_MS=30000
# IMAGING_QIDO_CACHE_TTL_MS=30000

# Upload (admin only; auto-enabled when NODE_ENV!=production)
# IMAGING_ENABLE_DEMO_UPLOAD=false
# IMAGING_MAX_UPLOAD_BYTES=536870912

# Ingest webhook (Orthanc OnStableStudy → API callback)
# IMAGING_INGEST_WEBHOOK_SECRET=dev-imaging-ingest-key-change-in-production

# DICOMweb-specific rate limiting (separate from general rate limiter)
# DICOMWEB_RATE_LIMIT=120
# DICOMWEB_RATE_WINDOW_MS=60000

# --- Phase 157: Audit JSONL Shipping to Object Store ---
# AUDIT_SHIP_ENABLED=false
# AUDIT_SHIP_ENDPOINT=http://localhost:9000
# AUDIT_SHIP_BUCKET=vista-evolved-audit
# AUDIT_SHIP_ACCESS_KEY=minioadmin
# AUDIT_SHIP_SECRET_KEY=minioadmin
# AUDIT_SHIP_REGION=us-east-1
# AUDIT_SHIP_INTERVAL_MS=300000
# AUDIT_SHIP_CHUNK_SIZE=1000
# AUDIT_SHIP_PATH_STYLE=true

# --- Phase 284: SaaS Billing / Metering ---
# BILLING_PROVIDER=mock              # mock (default, dev/test ONLY) or lago
#                                    # IMPORTANT: mock is BLOCKED in demo/pilot/prod environments.
#                                    # The API will refuse to start if mock is used outside dev/test.
# LAGO_API_URL=http://localhost:3000  # Lago API endpoint (only when BILLING_PROVIDER=lago)
# LAGO_API_KEY=                       # Lago API key (required for lago provider)
# METERING_FLUSH_INTERVAL_MS=60000    # How often to flush metering counters to billing provider
# DEPLOYMENT_STAGE=                   # Optional: demo | pilot | prod (blocks mock billing when set)

# --- Phase 285: Feature Flags Upgrade ---
# FEATURE_FLAG_PROVIDER=db            # db (default) or unleash
# UNLEASH_URL=http://localhost:4242/api  # Unleash API URL (only when FEATURE_FLAG_PROVIDER=unleash)
# UNLEASH_API_KEY=                    # Unleash client API token
# UNLEASH_APP_NAME=vista-evolved      # Application name for Unleash
# UNLEASH_REFRESH_INTERVAL_MS=15000   # Cache refresh interval for Unleash toggle polling
