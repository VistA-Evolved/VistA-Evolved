# Marketing Site Environment Variables
#
# This app uses Next.js static export (output: 'export').
# Environment variables prefixed with NEXT_PUBLIC_ are inlined at BUILD time.

# API server URL (used by signup form at build time)
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# Public site URL (used for OG meta tags and sitemap)
NEXT_PUBLIC_SITE_URL=https://vistaevolved.com
