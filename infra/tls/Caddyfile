# VistA-Evolved — Local Dev TLS Reverse Proxy
#
# Caddy auto-generates a self-signed CA and leaf cert for ehr.local.
# Trust the CA once: caddy trust (or use mkcert-bootstrap.ps1 for manual control).
#
# Usage:
#   docker compose -f infra/tls/docker-compose.tls.yml up -d
#
# Then access: https://ehr.local (add 127.0.0.1 ehr.local to hosts file)

{
	# Dev-mode: use internal CA (Caddy's built-in ACME-less issuer)
	local_certs
	# Disable admin API in dev proxy
	admin off
}

# HTTPS reverse proxy — ehr.local
ehr.local {
	# --- API routes ---
	handle /auth/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /vista/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /health {
		reverse_proxy host.docker.internal:3001
	}
	handle /ready {
		reverse_proxy host.docker.internal:3001
	}
	handle /metrics/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /admin/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /ws/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /imaging/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /rcm/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /telehealth/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /analytics/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /iam/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /posture/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /scheduling/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /intake/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /portal/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /api/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /version {
		reverse_proxy host.docker.internal:3001
	}
	handle /fhir/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /hl7/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /.well-known/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /security/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /hardening/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /audit/* {
		reverse_proxy host.docker.internal:3001
	}
	# Wave 17: facility/dept/workflow routes
	handle /facilities/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /departments/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /locations/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /dept-rbac/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /dept-packs/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /workflow/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /patient-comms/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /dept-scheduling/* {
		reverse_proxy host.docker.internal:3001
	}
	# Wave 18: event bus / webhooks / FHIR subs / plugins / marketplace
	handle /events/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /webhooks/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /fhir-subscriptions/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /plugins/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /ui-extensions/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /plugin-marketplace/* {
		reverse_proxy host.docker.internal:3001
	}
	# Other API routes that need proxying
	handle /marketplace/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /messaging/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /consent/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /platform/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /onboarding/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /compliance/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /queue/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /i18n/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /scim/* {
		reverse_proxy host.docker.internal:3001
	}
	handle /payerops/* {
		reverse_proxy host.docker.internal:3001
	}

	# --- Web frontend (catch-all) ---
	handle {
		reverse_proxy host.docker.internal:3000
	}

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
	}
}
