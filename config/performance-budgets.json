{
  "_meta": {
    "version": "1.0.0",
    "description": "VistA-Evolved Performance Budgets -- Phase 52",
    "updatedAt": "2026-02-21"
  },

  "webVitals": {
    "_doc": "Core Web Vitals targets for initial page loads. Measured in Lighthouse CI or synthetic monitoring.",
    "LCP": {
      "target": 2500,
      "unit": "ms",
      "description": "Largest Contentful Paint -- must be under 2.5s for good UX"
    },
    "FID": {
      "target": 100,
      "unit": "ms",
      "description": "First Input Delay -- must be under 100ms"
    },
    "CLS": {
      "target": 0.1,
      "unit": "score",
      "description": "Cumulative Layout Shift -- must be under 0.1"
    },
    "INP": {
      "target": 200,
      "unit": "ms",
      "description": "Interaction to Next Paint -- must be under 200ms"
    },
    "TTFB": {
      "target": 800,
      "unit": "ms",
      "description": "Time to First Byte -- must be under 800ms"
    }
  },

  "pageLoadBudgets": {
    "_doc": "Maximum JavaScript bundle sizes and page load times per route group.",
