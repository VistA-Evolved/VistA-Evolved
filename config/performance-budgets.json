      "maxLoadMs": 6000
    },
    "portalDashboard": {
      "maxJsBundleKB": 350,
      "maxTotalTransferKB": 500,
      "maxDOMContentLoadedMs": 2000,
      "maxLoadMs": 4000
    }
  },

